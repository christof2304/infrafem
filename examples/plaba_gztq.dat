!#!Kapitel Grenzzustand der Tragfähigkeit Bruchnachweis
$
$ *************************************************************
+PROG BEMESS urs:beme0001
KOPF Bemessung im Grenzzustand der TragfÃĪhigkeit nach DIN EN 1992-2:2010
$ WINGRAF massgebender Plot: Bemessung-FlÃĪchenelemente-Bewehrung ... Bemessungsfall 11
$       Bemessung-FlÃĪchenelemente-Spannung im Spannglied-Bemessungsspannung maximal .. Bemessungsfall 11
SEIT UNIE 0  ! Standard Eingabeeinheiten
$ Ergebnispruefung: Erforderliche Bewehrung in folgendem Plot
STEU QUER 0 $ keine Abminderung der Druckfestigkeit bei Querzug
STEU DBRU 2 $ Druckbewehrung auch erlaubt bei schiefem Druck
STEU LFB    11  $ Nummer der Bewehrungsverteilung
$ Da die Bewehrungsverteilungsnummer 1 fuer das Endergebnis
$ reserviert ist, wird hier ab Nummer 11 angefangen!
STEU BRUC $ GZT Bruchbemessung
LF desi $ DESI = alle mit Design gekennzeichneten MAXIMA Überlagerungslastfälle
LF 4046 "perm" $ Permanenter Zustand t-unendlich (ASE LF erforderlich zur genauen Ermittlung der max. Spannstahlspannung)
dust prue $ Durchstanzen nur pruefen -ohne Fehlermeldung
$ steu ro_v 0.50 $ kann im ersten BEMESS-PARA Lauf gesetzt werden, vgl. csm.dat\..\design\csm32_slab_design.dat!
$ dust ro_v 1.50 $ kann im ersten BEMESS-PARA Lauf gesetzt werden, vgl. csm.dat\..\design\csm32_slab_design.dat!
ENDE
$
+PROG WING urs:dwing101
KOPF Erforderliche Bewehrung 1. Lage nach Bruchnachweis
#define WINGDATA
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  SEIT UNIA 2   $ Einheiten = Hochbau Momente in kNm ...
  SIZE -urs M  100 Teil 3x1 hleg -1.5 tleg 1.5 $ Teil 3x1=3 Teilbilder über die Höhe $ urs = Querformat -urs = Hochformat
  SIZ2 UMBR AB
  BEOB EG3           $ Blickrichtung  3D
  grup - ja
  grup ausr,auns,astr,alan,ageo nein $ keine Achsen
  farb f25 0 ; farb f31 0 $ keine Spannstränge
  farb f16 0 ; $ Randelemente
  farb f23 0 ; farb f24 0 $ SIR-Schnitte
  grup - nein QUAD,RAND,FEDE
  BOX xmin ymin zmin  xmax ymax zmax $ BOX bei Bedarf
  STEU MESS 2D
  let#schr 0.27 ; SCHR H6 #schr $ Schrifthöhe
  $ Einheitliche Massstäbe für:
  let#fact_U        50 $ Überhöhung der Verformung
  let#beam_MY    50000 $ Massstab Momente    an Stäben
  let#beam_N     50000 $   " Normalkräfte    an Stäben
  let#quad_m      5000 $   " Biegemomentes   an quads
  let#quad_n      5000 $   " Normalkräfte    an quads
  let#quad_sig   10.00 $   " Spannungen      an quads  N/mm2
  let#quad_as   50.00 $   " Bewehrung       an Quadschnitten cm2/m
  let#beam_sig   10.00 $   " Spannungen      an Stäben N/mm2
  und 1 msca nein    $ Zentrierung Bilder auf Systemgrenzen
  schr prue 0        $ Schriftprüfung - wenig Überschreibungen
  sch2 MIN1 STAN MAX1 STAN $ Schriftwerte zurücksetzen
  STEU LEER JA       $ falls BEMESS Fehler - andere Werte plotten
#enddef
#define WING_CUT
$
  grup - ja
  grup - nein RAND,FEDE
move         $ erzeuge einen QUAD-Schnitt bei y=:
  grup - ja
@KEY 10 0; LET#xmin @7  ; LET#ymin @8
           LET#xmax @10 ; LET#ymax @11
         $ xmin,ymin,xmax,ymax aus der .CDB gelesen
LET#yy 0.25*#ymin+0.75*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
LET#yy 0.50*#ymin+0.50*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
LET#yy 0.75*#ymin+0.25*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
         $ Schnitt in X-Richtung bei y=#yy m
$
#enddef
#define WINGBOXGRP
$
GRUP - nein
  GRUP   1
  GRUP   2
  GRUP   3
#enddef
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Erforderliche Bewehrung 1. Lage nach Bruchnachweis
LF BEME   11 $ Bewehrungsverteilungsnummer
  DSGN TYP LINE DTYP -Z $ Spannungen am Schnitt->Z
  QUAD ASOH #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K ;und
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD ASUH UNIT #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K
  BEOB XY           $ Blickrichtung
  QUAD ASOH DARS DHOH STYP E2K
  QUAD ASUH DARS DHOH STYP E2K
ENDE
$
+PROG WING urs:dwing102
KOPF Erforderliche Bewehrung 2. Lage nach Bruchnachweis
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Erforderliche Bewehrung 2. Lage nach Bruchnachweis
LF BEME   11 $ Bewehrungsverteilungsnummer
  DSGN TYP LINE DTYP -Z $ Spannungen am Schnitt->Z
  QUAD ASOQ #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K ;und
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD ASUQ UNIT #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K
  BEOB XY           $ Blickrichtung
  QUAD ASOQ DARS DHOH STYP E2K
  QUAD ASUQ DARS DHOH STYP E2K
ENDE
$
+PROG WING urs:dwing113
KOPF Max. Spannstahlspannung Zustand II im Bruchnachweis
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
 MOVE X 1  5 UNIT PR SCHR .28 F 1001 DTYP TEXT
TEXT Max. Spannstahlspannung Zustand II im Bruchnachweis
LF BEME   11
  DSGN  TYP LINE DTYP Z ; STAB SGMA DARS DLIN SCHR #schr
$ Auswahl von Straengen moeglich mit WING-SEL-QTEN
ENDE
$
$ *************************************************************
!#!Kapitel Maximum der erforderlichen Bewehrung
+PROG BEMESS urs:beme0008
KOPF Maximum der erforderlichen Bewehrung
$ WINGRAF massgebender Plot: Bemessung-FlÃĪchenelemente-Bewehrung ... Bemessungsfall 1
STEU LFBI    11 $ Bruchnachweis
STEU LFB     1  $ Nummer der gespeicherten Bewehrungsverteilung (Maximum). Alte Ergebnisse dieser Nummer werden gelöscht.
BEW BEZ 'Maximum der Bewehrung'
ENDE
$
+PROG WING urs:dwing104
KOPF Erf. Bewehrung 1. Lage  LFB 1 = Maximum aller Nachweise
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Erf. Bewehrung 1. Lage  LFB 1 = Maximum aller Nachweise
LF BEME   -1 $ Bewehrungsverteilungsnummer
  DSGN TYP LINE DTYP -Z $ Spannungen am Schnitt->Z
  QUAD ASOH #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K ;und
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD ASUH UNIT #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K
  BEOB XY           $ Blickrichtung
  QUAD ASOH DARS DHOH STYP E2K
  QUAD ASUH DARS DHOH STYP E2K
ENDE
$
+PROG WING urs:dwing105
KOPF Erf. Bewehrung 2. Lage  LFB 1 = Maximum aller Nachweise
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Erf. Bewehrung 2. Lage  LFB 1 = Maximum aller Nachweise
LF BEME   -1 $ Bewehrungsverteilungsnummer
  DSGN TYP LINE DTYP -Z $ Spannungen am Schnitt->Z
  QUAD ASOQ #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K ;und
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD ASUQ UNIT #quad_as ND 2 DARS DCUT SCHR #schr STYP E2K
  BEOB XY           $ Blickrichtung
  QUAD ASOQ DARS DHOH STYP E2K
  QUAD ASUQ DARS DHOH STYP E2K
ENDE
$
+PROG WING urs:dwing106
KOPF Erforderliche Bewehrung LFB 1 = Maximum aller Nachweise
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 1x1 hleg -1.5 tleg 1.0
  let#schr 0.22 ; SCHR H6 #schr $ Schrifthoehe
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Erforderliche Bewehrung LFB 1 = Maximum aller Nachweise
LF BEME   -1 $ Bewehrungsverteilungsnummer
  DSGN TYP LINE DTYP -Z $ Spannungen am Schnitt->Z
LF BEME   -1 $ Bewehrungsverteilungsnummer STYP E2K ;und
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
LF BEME   -1 $ Bewehrungsverteilungsnummer STYP E2K ;und STYP E2K
  BEOB XY           $ Blickrichtung
  QUAD ASSB DARS DHOH STYP E2K
  let#schr 0.19 ; SCHR H6 #schr $ Schrifthoehe
  QUAD  ASS DARS DSCH
  QUAD  ASO DARS DSCH
  QUAD  ASU DARS DSCH
ENDE
