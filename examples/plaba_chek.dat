$ *************************************************************
$ Folgend eine PICT-Bildeingabe mit Erl‰uterungen - siehe Report
$ *************************************************************
$
$ PICT - defining a picture - all in [cm]
<PICT> XCM 18.0 YCM 12.0 TEXT 'Plot Bruchnachweis - Grenzzustand der Tragf‰higkeit                                                                                                                                                    '
$
$ GNT ñ scaling of the pict area: from 0.0->1.0 :
GNT 1 -1 XMIN 0.0 XMAX 1.0 YMIN 0.0 YMAX 1.05
$
$ draw lines: - here a surrounding box:
let#y 0.04 ; GPL x1 0.02 #y x2 0.98 #y x3 0.98 1.03 x4 0.02 1.03 x5 0.02 #y
$
$ GTXI - Test attributes : H in [cm]
GTXI H 0.31 HALI LEFT VALI HALF
$
$ text:
GTXT  X 0.05 Y 0.98 TEXT 'Plot Bruchnachweis - Grenzzustand der Tragf‰higkeit                                                                                                                                                    '
GPL x1 0.05 0.95 x2 0.60 0.95
GPL x1 0.05 0.94 x2 0.60 0.94
GTXT  X 0.05 Y 0.90 TEXT 'Die folgenden Plots zeigen nichtlineare Querschnittsspannungen (Zustand II)                        '
GTXT  X 0.05 Y 0.85 TEXT 'des 2. CSM-DESI Check Print AQB Laufes: "Bruchnachweis"                                            '
GTXT  X 0.05 Y 0.80 TEXT 'Die hier benutzten Lastfallnummern kˆnnen auch in WINGRAF f¸r Plots                                '
GTXT  X 0.05 Y 0.75 TEXT 'von Schnittgrˆþen und Spannungen am Gesamtsystem verwendet werden.                                 '
let#xli 0.15 ; let#xre 0.45 ; let#ytop 0.70 ; let#ybot 0.40 ; let#ym 0.5*(#ytop+#ybot)
GPL #xli #ytop  #xre #ytop  #xre #ybot  #xli #ybot  #xli+0.01 #ym  #xli-0.01 #ym  #xli #ytop
$ Parabel
let#x00 #xre+0.20 ; let#y00 #ytop ; let#dx 0.06 ; let#dy 0.12 ; let#u0 0.0 ; let#v0 0.0
let#y #y00-0.1*#dy ; GPL #x00 #y   #x00 #y00   #x00+#dx #y00   #x00+#dx #y ; let#y00 #y
let#y #y00-0.1*#dy ; GPL #x00 #y   #x00 #y00   #x00+#dx #y00   #x00+#dx #y ; let#y00 #y
loop 10 ; let#u1=#u0+0.1 ; let#v1=#u1*#u1 $ Parabel
  let#x0 #x00+(1.0-#v0)*#dx ; let#y0 #y00-#u0*#dy
  let#x1 #x00+(1.0-#v1)*#dx ; let#y1 #y00-#u1*#dy
  GPL #x00 #y1   #x00 #y0   #x0 #y0   #x1 #y1 ; let#u0 #u1 ; let#v0 #v1
endloop
  GPL #x00 #y1   #x00 #ybot
  let#y #ybot+0.022 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
  let#y #ybot+0.026 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
let#x #xli+0.3*(#xre-#xli) $ crack:
GPL #x-.005 #ybot  #x-.002 #ybot+.06  #x-.004 #ybot+.11  #x #ybot+.16  #x-0.002 #ybot+.12  #x+.002 #ybot+.06  #x+.001 #ybot
let#x #xli+0.8*(#xre-#xli)
GPL #x-.005 #ybot  #x-.002 #ybot+.06  #x-.004 #ybot+.11  #x #ybot+.16  #x-0.002 #ybot+.12  #x+.002 #ybot+.06  #x+.001 #ybot
GTXT X #x00+#dx+0.01 Y #ytop-0.05 TEXT '- negativ                                                                                          '
GTXT X #x00+#dx+0.01 Y #ytop-0.09 TEXT 'nichtlinearer                                                                                      '
GTXT X #x00+#dx+0.01 Y #ytop-0.13 TEXT 'Druck                                                                                              '
GTXT X #x00+0.05     Y #ybot+0.07 TEXT 'Bruchnachweis                                                                                      '
GTXT X #x00-0.10     Y #ybot+0.07 TEXT '+ Zug                                                                                              '
GTXI H 0.26 HALI LEFT VALI HALF
GTXT  X 0.10 Y 0.36 TEXT 'Bei "rel" =1.00 im AQB Lauf ist der Querschnitt genau ausgenutzt und wir sehen hier                '
GTXT  X 0.10 Y 0.33 TEXT 'die Spannungen f¸r die Schnittgrˆþen der GZT Bruchkombination.                                     '
GTXT  X 0.10 Y 0.30 TEXT 'Bei "rel" > 1.00 hat der Querschnitt aber rel-fache Reserven. Die hier dargestellten               '
GTXT  X 0.10 Y 0.27 TEXT 'Spannungen zeigen dann den Grenzzustand des maximal aufnehmbaren inneren Moments MyRd              '
GTXT  X 0.10 Y 0.24 TEXT 'das rel-fach grˆþer ist als das einwirkende Moment der GZT Kombination!                            '
GTXI H 0.26 HALI LEFT VALI HALF
GTXT  X 0.10 Y 0.19 TEXT 'In WINGRAF kˆnnen Sie auf folgende GZT Bruchmomente zugreifen:                                     '
GTXT  X 0.10 Y 0.16 TEXT 'LF 2105 = Max-My Kombination Bruchnachweis ohne NV0, MV0 = externe Belastung ohne NV0, MV0         '
GTXT  X 0.10 Y 0.13 TEXT 'LF 2106 = Min-My   "                                                                               '
GTXT  X 0.10 Y 0.10 TEXT 'LF 2117 = Max-My Kombination Bruchnachweis mit NV0, MV0                                            '
GTXT  X 0.10 Y 0.07 TEXT 'LF 2118 = Min-My   "                                                                               '
</PICT>
$ End of picture
ENDE
ENDE
$
+PROG RESULTS urs:kresult6
KOPF Plot Spannungen im Rissnachweis
SIZE URS M  0
let#AQUP_sig      5000 $ 1 cm entspricht #AQUP_sig kN/m2
let#AQUP_sss     25000 $ Betonstahlspannungen
  STEU WARN 802,821 $ falls der Querschnitt keine Bewehrung hat kommt sonst eine Warnung
$
LET#LF   9395
 BILD BEZ "Check Rissnachweis max-MY LFSP 9395 Stab 1008 x= 0.00"
  LET#N      1008 ; LET#x     0.000[m] ; LF #LF ENR #N x #x
  QUER TYP BWSS ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN UNIT -
LET#LF   9396
 BILD BEZ "Check Rissnachweis min-MY LFSP 9396 Stab 1008 x= 0.00"
  LET#N      1008 ; LET#x     0.000[m] ; LF #LF ENR #N x #x
  QUER TYP BWSS ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN UNIT -
$ *************************************************************
$ Folgend eine PICT-Bildeingabe mit Erl‰uterungen - siehe Report
$ *************************************************************
$
$ PICT - defining a picture - all in [cm]
<PICT> XCM 18.0 YCM 12.0 TEXT 'Plot Spannungen im Rissnachweis                                                                                                                                                                        '
$
$ GNT ñ scaling of the pict area: from 0.0->1.0 :
GNT 1 -1 XMIN 0.0 XMAX 1.0 YMIN 0.0 YMAX 1.05
$
$ draw lines: - here a surrounding box:
let#y 0.37 ; GPL x1 0.02 #y x2 0.98 #y x3 0.98 1.03 x4 0.02 1.03 x5 0.02 #y
$
$ GTXI - Test attributes : H in [cm]
GTXI H 0.31 HALI LEFT VALI HALF
$
$ text:
GTXT  X 0.05 Y 0.98 TEXT 'Plot Spannungen im Rissnachweis                                                                                                                                                                        '
GPL x1 0.05 0.95 x2 0.60 0.95
GPL x1 0.05 0.94 x2 0.60 0.94
GTXT  X 0.05 Y 0.90 TEXT 'Die folgenden Plots zeigen nichtlineare Querschnittsspannungen (Zustand II)                        '
GTXT  X 0.05 Y 0.85 TEXT 'des 3. CSM-DESI Check Print AQB Laufes: "Rissnachweis"                                             '
GTXT  X 0.05 Y 0.80 TEXT 'Die hier benutzten Lastfallnummern kˆnnen auch in WINGRAF f¸r Plots                                '
GTXT  X 0.05 Y 0.75 TEXT 'von Schnittgrˆþen und Spannungen am Gesamtsystem verwendet werden.                                 '
let#xli 0.15 ; let#xre 0.45 ; let#ytop 0.70 ; let#ybot 0.40 ; let#ym 0.5*(#ytop+#ybot)
GPL #xli #ytop  #xre #ytop  #xre #ybot  #xli #ybot  #xli+0.01 #ym  #xli-0.01 #ym  #xli #ytop
$ Parabel
let#x00 #xre+0.20 ; let#y00 #ytop ; let#dx 0.04 ; let#dy 0.12 ; let#u0 0.0 ; let#v0 0.0
let#y #y00-0.1*#dy ; GPL #x00 #y   #x00 #y00   #x00+#dx #y00   #x00+#dx #y ; let#y00 #y
let#y #y00-0.1*#dy ; GPL #x00 #y   #x00 #y00   #x00+#dx #y00   #x00+#dx #y ; let#y00 #y
loop 10 ; let#u1=#u0+0.1 ; let#v1=#u1*#u1 $ Parabel
  let#x0 #x00+(1.0-#v0)*#dx ; let#y0 #y00-#u0*#dy
  let#x1 #x00+(1.0-#v1)*#dx ; let#y1 #y00-#u1*#dy
  GPL #x00 #y1   #x00 #y0   #x0 #y0   #x1 #y1 ; let#u0 #u1 ; let#v0 #v1
endloop
  GPL #x00 #y1   #x00 #ybot
  let#y #ybot+0.022 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
  let#y #ybot+0.026 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
let#x #xli+0.3*(#xre-#xli) $ crack:
GPL #x-.005 #ybot  #x-.002 #ybot+.06  #x-.004 #ybot+.11  #x #ybot+.16  #x-0.002 #ybot+.12  #x+.002 #ybot+.06  #x+.001 #ybot
let#x #xli+0.8*(#xre-#xli)
GPL #x-.005 #ybot  #x-.002 #ybot+.06  #x-.004 #ybot+.11  #x #ybot+.16  #x-0.002 #ybot+.12  #x+.002 #ybot+.06  #x+.001 #ybot
GTXT X #x00+#dx+0.01 Y #ytop-0.05 TEXT '- negativ                                                                                          '
GTXT X #x00+#dx+0.01 Y #ytop-0.09 TEXT 'nichtlinearer                                                                                      '
GTXT X #x00+#dx+0.01 Y #ytop-0.13 TEXT 'Druck                                                                                              '
GTXT X #x00+0.05     Y #ybot+0.07 TEXT 'Rissnachweis                                                                                       '
GTXT X #x00-0.10     Y #ybot+0.07 TEXT '+ Zug                                                                                              '
</PICT>
$ End of picture
ENDE
ENDE
