$ text:
GTXT  X 0.05 Y 0.98 TEXT 'Plot Spannungen in Kombinationen selten/h‰ufig/permanent                                                                                                                                               '
GPL x1 0.05 0.95 x2 0.60 0.95
GPL x1 0.05 0.94 x2 0.60 0.94
GTXT  X 0.05 Y 0.90 TEXT 'Die folgenden Plots zeigen linear ermittelte Querschnittsspannungen des                            '
GTXT  X 0.05 Y 0.85 TEXT 'ersten CSM-DESI Check Print AQB Laufes: "Spannungen in Kombinationen"                              '
GTXT  X 0.05 Y 0.80 TEXT 'Die hier benutzten Lastfallnummern kˆnnen auch in WINGRAF f¸r Plots                                '
GTXT  X 0.05 Y 0.75 TEXT 'von Schnittgrˆþen und Spannungen am Gesamtsystem verwendet werden.                                 '
let#xli 0.15 ; let#xre 0.45 ; let#ytop 0.70 ; let#ybot 0.40 ; let#ym 0.5*(#ytop+#ybot)
GPL #xli #ytop  #xre #ytop  #xre #ybot  #xli #ybot  #xli+0.01 #ym  #xli-0.01 #ym  #xli #ytop
$ Linear (Parabel)
let#x00 #xre+0.20 ; let#y00 #ytop ; let#dx 0.05 ; let#dy #ytop-#ybot ; let#xi +1.0
loop 21 ; let#x #x00+#xi*#dx ; let#y #y00+(#xi-1.0)*#dy/2
  GPL #x00 #y   #x #y ; let#xi #xi-0.1
endloop
  GPL #x00+#dx #ytop   #x00 #ytop   #x00 #ybot   #x00-#dx #ybot  #x00+#dx #ytop
  let#y #ybot+0.022 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
  let#y #ybot+0.026 ; GPL #xli+0.002 #y   #xre #y ; GPL #x00-0.12 #y   #x00 #y
GTXT X #x00+#dx+0.01 Y #ytop-0.05 TEXT 'linear                                                                                             '
GTXT X #x00+#dx+0.01 Y #ytop-0.09 TEXT 'N/A + M/w                                                                                          '
GTXT X #x00-0.10     Y #ybot+0.07 TEXT '+ Zug                                                                                              '
GTXT  X 0.05 Y 0.35 TEXT 'Die Kombination ULS_SPAN[P0] zeigt lineare Spannungen der GZT Bruchkombination                     '
GTXT  X 0.05 Y 0.30 TEXT 'und wird meist nur im Verbundbau benˆtigt.                                                         '
GTXT  X 0.05 Y 0.25 TEXT 'Im Spannbetonbau dient diese Kombination nur zur Ausgabe des einwirkenden                          '
GTXT  X 0.05 Y 0.20 TEXT 'GZT Bruchmoments inclusive dem statisch bestimmten Anteil der Vorspannung MV0.                     '
</PICT>
