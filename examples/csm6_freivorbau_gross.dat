+PROG SOFIMSHC urs:5
KOPF Achse für SOFILOAD Lastenzüge, SSD Tendons, Animator Umwelt
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
SYST REST
GAX 'AX_1'
GAXC  X    Y    Z     $ create an axis through a set of points
      1443.650    0  -16.244
      1499.000    0  -19.565
      1568.020    0  -23.665
      1616.000    0  -24.954
      1680.560    0  -23.062
      1732.200    0  -19.963
      1786.350    0  -17.410
ENDE

+PROG SOFILOAD urs:11
KOPF Definition der Einwirkungen Lasten
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
ECHO ACT VOLL $ Bitte prüfen Sie die GAMU Werte
ACT G_1
ACT G_2
ACT P
ACT C
$
$ Lasten, die im CSM verwendet werden sollten mit TYP none definiert werden, da die Bauphasen im CSM einen eigenen Typ erhalten!
ENDE

+PROG TENDON urs:9
KOPF Prestressing  top tendons
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
STEU WARN 723,725,420 $ Anpassen der Spannungen fy - Brückenbautabelle
$ Definition des Spannverfahrens:
$ Wir empfehlen, alle Daten als benutzerdefiniertes Spannverfahrens
$ explizit einzugeben. Für die Statik sind folgende Werte ausreichend:
SYSP NRSV MAT   ZV       AZ    LITZ MINR   BETA  MUE EXZ  SS     DA
        1  11 3848[kN] 2850[mm2] 19 6.50[m] 0.3 0.21 2[mm] 6[mm] 97[mm] $ top tendons csm31_beam 19 wires
        2  11 3848[kN] 2850[mm2] 19 6.50[m] 0.3 0.21 2[mm] 6[mm] 97[mm] $ bottom tendons
        3  11 3848[kN] 2850[mm2] 19 6.50[m] 0.3 0.21 2[mm] 6[mm] 10[mm] $ external: no extra duct hole -> 10[mm]
$
#define tendonplot
  SIZE URS
  PLOT GEOA NR #not FAKH  4 TYPG DUTE
#enddef

$ reference axis and span definition:
AXES NRH 1 TYP AUTO 101 202

let#pier 1
let#piernode 119
let#nrloc 1 $ *10+1 gives construction stage number for top tendons
#define toptendon
  let#not   #pier*100+#nrloc
  let#ics1  #nrloc*10+1
  let#nn DIV(#nrloc,2) $ = #nrloc/2: 1->0 3->1 5->2 7->3...
  let#node1 #piernode-2-#nn   $ starting node of tendon
  let#node2 #piernode+2+#nn   $ ending   node of tendon
  let#beam1 (#node1-100)*10   $ starting beam of tendon
  let#beam2 (#node2-100-1)*10 $ ending   beam of tendon
  SGEO NRG #not NRH 1 NRSV 1
  ZPUV  S        X      U      V        DVS  TYP=STAB
       #beam1    0.000  0.000  0.430
       #beam1+10 0.000  0.000  0.306     0
       #beam2    =      =      =         0
       #beam2+10 0.000  =      0.430
  if MOD(#not,2)==1
    VSIG 'RE' ANWS 9 KAPA 1.5 K3 1280
  else
    VSIG 'LI' ANWS 9 KAPA 1.5 K3 1280
  endif
  CS IBA1 #ics1 #ics1+1
  TEND #not NRG #not NSP 2 LF #ics1
                      $   2 Attention: NSP=2
    #include tendonplot
  let#nrloc #nrloc+2
#enddef
#include toptendon $ ICS1  11
#include toptendon $ ICS1  31
#include toptendon $ ICS1  51
#include toptendon $ ICS1  71
$
let#pier 2
let#piernode 138
let#nrloc 3 $ *10+1 gives construction stage number for top tendons
#include toptendon $ ICS1  31
#include toptendon $ ICS1  51
#include toptendon $ ICS1  71
#include toptendon $ ICS1  91
#include toptendon $ ICS1 111
#include toptendon $ ICS1 131
#include toptendon $ ICS1 151
#include toptendon $ ICS1 171
#include toptendon $ ICS1 191
#include toptendon $ ICS1 211
#include toptendon $ ICS1 231
ENDE
$
