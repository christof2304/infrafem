$
#define project= "csm6_freivorbau_gross"
$ ******************* Construction Stage Manager **************
$
$ Eine Übersicht über Lastfälle, Bauzustände, Gruppenparamter
$ sowie eine Zusammenstellung der Kriechbeiwerte ist in der
$ CSM-Ausgabedatei zu finden.
$
$ ******************* Construction Stage Manager **************
$PROG ASE
#define ASE_CTRL
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  ECHO vers,schn,nost,bett,last,reak,grup,lsum nein
  STEU DIFF 1000 $ Differenzlastfälle Inkrement
  STEU KRAG   12 $ 1 = Vorbau mit Ausgangsneigung
                 $ 2 = tangentialer Vorbau
#enddef
$
$PROG AQB
#define AQB_CTRL
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  ECHO schn,komb,span,eige nein
  STEU EIGE 1+2+64
  STEU QWF   1.00000 $ Berücksichtigung der Bewehrung bei K+S
  STEU VM   VAL2 1.0 $ Längskraft delta-N infolge Torsion in der Biegebemessung BEME berücksichtigen
#enddef
$
#define AQB_STAB
 STAB BA auto
#enddef
$ *************************************************************
$ *************************************************************
$ *************************************************************
!#!Kapitel CSM Bauphasen
$ ----------------------------------- Construction Stage   1  ----------------
+PROG ASE urs:csmase1
KOPF Bauabschnitt BA   1 Piers
sto#ba_csm   1    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF -
GRUP   0 BA   1 FAKG 1
LF  4001  TYP - BEZ "Piers                           " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
ENDE
$ ----------------------------------- Construction Stage  10  ----------------
$ Diesen LF in gleichem PROG ASE rechnen =schneller
$ PROG ASE urs:csmase10
KOPF Bauabschnitt BA  10 Pier table
sto#ba_csm  10    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
