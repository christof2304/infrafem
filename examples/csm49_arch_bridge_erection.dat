+prog sofimsha urs:30.1
KOPF Group title for WINGRAF:
SYST REST ; STEU REST 2
GRUP   1    BEZ 'Pylon'
GRUP   2    BEZ 'Pylon cable transverse'
GRUP   3    BEZ 'Pylon cable backstay'
GRUP   9    BEZ 'Main lowering cable'
GRUP  11,21 BEZ 'Arch part 1'
GRUP  12,22 BEZ 'Arch part 2'
GRUP  13,23 BEZ 'Arch closing segment'
GRUP 101,102,103,104 BEZ 'Superstructure'
GRUP 201,202,203,204 BEZ 'Hanger'
ENDE

+prog sofiload urs:3
KOPF
LF 901 TYP none BEZ 'adjust backstay cable'
  SEIL GRP 3 TYP WX PA -110 $ mm shortening
LF 902 TYP none BEZ 'adjust cable in between'
  SEIL GRP 9 TYP WX PA -90 $ mm shortening
LF 903 TYP none BEZ 'adjust cable for welding'
  SEIL GRP 9 TYP WX PA  +3 $ mm lengthening

LF 201 TYP none BEZ 'hanger shortening'
  SEIL GRP 201 TYP WX PA -10 $ mm shortening
LF 202 TYP none BEZ 'hanger shortening'
  SEIL GRP 202 TYP WX PA -10 $ mm shortening
LF 203 TYP none BEZ 'hanger shortening'
  SEIL GRP 203 TYP WX PA -10 $ mm shortening
LF 204 TYP none BEZ 'hanger shortening'
  SEIL GRP 204 TYP WX PA -10 $ mm shortening

ENDE

!#!Kapitel CSM
+PROG CSM URS:4
KOPF Arch rotation
$ CTRL TEST ANI $ Then ASE only sto{res the lauching data for the animator without really analyzing something
TAKT GRP 11,12 XM -40.033[m] ZM -29.945[m] PHI +1 NR_T 1
TAKT GRP 21,22 XM +40.033[m] ZM -29.945[m] PHI +1 NR_T 2
$
BA      10            TYP G_1 BEZ 'Pylon'                    ; GRUP  1 IBA1 10
BA      20            TYP G_1 BEZ 'Cable transverse'         ; GRUP  2 IBA1 20
BA      30            TYP G_1 BEZ 'Cable bach stay'          ; GRUP  3 IBA1 30

let#phi 50 $ degree
let#cs 111 ; BA #cs   TYP G_1 BEZ 'Arch part 1 without dead load' TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
                                                                GRUP 11,21 IBA1 #cs IBAG #cs+1
                                                                GRUP 9     IBA1 #cs IBAG #cs+1 WBIS 249
             BA #cs+1 TYP G_1 BEZ 'Arch part 1 dead load'         TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
let#cs 121 ; BA #cs   TYP G_1 BEZ 'Arch part 2 without dead load' TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
                                                                GRUP 12,22 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Arch part 2 dead load'         TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
let#phi 40 ; BA   201 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
let#phi 30 ; BA   202 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
let#phi 20 ; BA   203 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180

let#cs 210 ; BA #cs   TYP G_1 BEZ 'adjust backstay cable'         TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180

let#phi 10 ; BA   211 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
                                                                 LF 901 IBA1 #cs
let#cs 212 ; BA #cs   TYP G_1 BEZ 'adjust main cable'             TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
                                                                 LF 902 IBA1 #cs

let#phi  5 ; BA   212 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180
let#phi  0 ; BA   213 TYP G_1 BEZ 'Arch lowering'                 TAKT #phi*3.1416/180 TAK2 -#phi*3.1416/180

let#cs 220 ; BA #cs   TYP G_1 BEZ 'adjust cable for welding'  ; LF 903 IBA1 #cs

let#cs 221 ; BA #cs   TYP G_1 BEZ 'Closure segment =welding'  ; GRUP 13,23 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Closure segment dead load'

let#cs 250 ; BA #cs   TYP G_1 BEZ 'remove main cable'

let#cs 300 ; BA #cs   TYP G_1 BEZ 'Segment+hanger without dl' ; GRUP 101,201 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Segment+hanger dead load'
             BA #cs+2 TYP G_1 BEZ 'Stress hanger dead load'   ; LF 201 IBA1 #cs+2
let#cs 310 ; BA #cs   TYP G_1 BEZ 'Segment+hanger without dl' ; GRUP 102,202 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Segment+hanger dead load'
             BA #cs+2 TYP G_1 BEZ 'Stress hanger dead load'   ; LF 202 IBA1 #cs+2
let#cs 320 ; BA #cs   TYP G_1 BEZ 'Segment+hanger without dl' ; GRUP 103,203 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Segment+hanger dead load'
             BA #cs+2 TYP G_1 BEZ 'Stress hanger dead load'   ; LF 203 IBA1 #cs+2
let#cs 330 ; BA #cs   TYP G_1 BEZ 'Segment+hanger without dl' ; GRUP 104,204 IBA1 #cs IBAG #cs+1
             BA #cs+1 TYP G_1 BEZ 'Segment+hanger dead load'
             BA #cs+2 TYP G_1 BEZ 'Stress hanger dead load'   ; LF 204 IBA1 #cs+2

STEU SPEI 0 ; SCAL AQ_S 0 $ no AQB check print = quicker
ENDE
+apply $(NAME)_csm.dat


$ Dateiordner aufräumen:
+sys del $(project).$d?

