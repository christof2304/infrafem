QS 1 S


let#no 126 ; let#h $(h126) ; let#w   0.30
#define cross1
QNR #no MNR  1
QPOL  UPZ MNR 1
QP    Y   Z   $ EXP
     0.00 0.00  $ 0.10 $ low connection to EXP
     3.50 0.09
     5.58 0.09
     5.58 0.29
     3.00 0.43
     2.75 1.69
     =    #h
QPOL  UPZ MNR 0
QP    Y   Z   $ EXP
     0.00 0.34  $ 0.50 $ low connection to EXP
     0.85 =
     2.15 0.43
let#r 2.75-#w-2.15
     2.75-#w 0.43+#r
     =    #h-0.40+((#w-0.30)/6)
     1.55 #h-0.25
QS 1 S

#enddef
#include cross1

