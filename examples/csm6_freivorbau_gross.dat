!#!KAPITEL Material and System generation
+PROG AQUA urs:1
KOPF
SEIT 1 SPRA 1
NORM DIN 'en199X-200X' $ cat C $ DIN FACHBERICHT 102 vgl. DIN_FB_SOFiSTiK Beispiel
STEU STYP BEM
UNIT 0  $ Einheiten in m
BETO  1 C 30
STAH  2 S 500
STAH 11    Y '1860A' $ prestessing steel
                    $ fp0,1k = 1600 N/mm2
                    $ fpk    = 1860 N/mm2
                    $            0.8*fpk    = 0.80*1860 = 1488 N/mm2
                    $            0.9*fp0,1k = 0.90*1600 = 1440 N/mm2
                    $ sigp,max = min(1488,1440)         = 1440 N/mm2 EN-1992-1-1 5.10.2.1(1) maximale Spannung
                    $ sigp,SLS = 0.65*fpk   = 0.65*1860 = 1209 N/mm2 EN-1992-1-1 7.2(5)      bei Verkehrsübergabe quasiständig
                    $ sigp,rare= sigp,max
QNR 1 MNR  1
QPOL  UPZ MNR 1
QP    Y   Z
     0.00 0.00
     3.50 0.09
     5.58 0.09
     5.58 0.29
     3.00 0.43
     2.75 1.69
     2.75 2.69
QPOL  UPZ MNR 0
QP    Y   Z
     0.00 0.34
     0.85 0.34
     2.15 0.43
     2.45 0.73
     2.45 2.29
     1.55 2.44
QS 1 S

QNR 2 MNR  1
QPOL  UPZ MNR 1
QP    Y   Z
     0.00 0.00
     3.50 0.09
     5.58 0.09
     5.58 0.29
     3.00 0.43
     2.75 1.69
     2.75 2.69
QPOL  UPZ MNR 0
QP    Y   Z
     0.00 0.34
     0.85 0.34
     2.15 0.43
     2.35 0.63
     2.35 2.307
     1.55 2.44
QS 1 S

QNR 3 MNR  1
QPOL  UPZ MNR 1
QP    Y   Z
     0.00 0.00
     3.50 0.09
     5.58 0.09
     5.58 0.29
     3.00 0.43
     2.75 1.69
     2.75 2.69
QPOL  UPZ MNR 0
QP    Y   Z
     0.00  0.69
     0.375 0.69
     0.375 2.19
QS 1 S

QNR 4 MNR  1
QPOL  UPZ MNR 1
QP    Y   Z
     0.00 0.00
     3.50 0.09
     5.58 0.09
     5.58 0.29
     3.00 0.43
     2.75 1.69
     2.75 5.19
QPOL  UPZ MNR 0
QP    Y   Z
     0.00  2.79
     0.375 2.79
     0.375 4.29
QS 1 S

QB  NR  5  H  0.30[m]  B  11.16[m]  REF  OM
$
$
QNR 6 MNR  1
QPOL  UPY MNR 1
QP    Y     Z
    2.5000  0.0000
    1.7999  0.8574
    0.6200  1.0980
    0.6000  1.0000
   -0.6000  1.0000
