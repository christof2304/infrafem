<text> <u><b> Ăśberlagerungskombinationen: </u></b>
      rare, nonf, freq, perm, temp, 1.0*, desi, acci, earq, robu, fatigue
  LC  1120, 1220, 1320, 1420, 1820, 1920, 2120, 2520, 2620, 2720, 2820, 2920
  Type=Y_1,  Y_2,  Y_3,  Y_4,  Y_8,  Y_9,  Y_D,  Y_A,  Y_E,  Y_R,  Y_F,  Y_G
.
