+PROG TENDON urs:7
KOPF    bottom tendons
STEU WARN 723,725,420
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
#define seth
let#h(205) 0 $ Feld #h(0:999) anlegen
loop#i 205
  let#h(#i) 2.709   $ alle Feldelemente mit 2.709 vorbelegen
endloop
prt#h(10)     $ testprint
$ jetzt alle anders definierten belegen:
let#h(126)    $(h126)
