+PROG TENDON urs:8
KOPF    external tendons
STEU WARN 723,725,420
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
#include seth
let#field 2
let#pierleft   119   $ piernodes:       119,138,165,184
let#centerleft 128 $ left node of centerbeam
let#pierright  138
let#addinside 0
let#ics1 711
let#not  721 $ number of first tendon
let#nrloc 1
#define extern
  let#node1 #centerleft-#nrloc-#addinside   $ left  Umlenksattel
  let#node2 #centerleft+#nrloc+1+#addinside $ right Umlenksattel
  let#beama (#pierleft-100)*10   $ beam x=0 pierleft
  let#beam1 (#node1-100)*10      $ beam x=0 left  Umlenksattel
  let#beam2 (#node2-100)*10      $ beam x=0 right Umlenksattel
  let#beame (#pierright-100)*10  $ beam x=0 pierright
  let#dzbot 0.50
  if #node2-#node1>9
    let#dzbot 0.90  $ damit in Feldmitte nicht unten rausschauen
  endif
  SGEO NRG #not NRH 1 NRSV 3
  ZPGV  S        X      U      V          TYP=STAB
       #beama    0.000  0.000  0.600
       #beam1    0.000  0.000  #h(#node1)-#dzbot
       #beam2    0.000  0.000  #h(#node2)-#dzbot
       #beame    0.000  =      0.600
  VSIG 'RE' ANWS 1 KAPA 0 K3 1180
  CS IBA1 #ics1 IBA2 999 $  999 = external !
  TEND #not NRG #not NSP 2 LF #ics1 BEZ 'externfield #field'
                      $   2 Attention: NSP=2
    #include tendonplot
  let#nrloc #nrloc+1
  let#not   #not+1
#enddef
#include extern    $ ICS1 711
#include extern    $
#include extern    $
#include extern    $
$
let#field 3
let#pierleft   138   $ piernodes:       119,138,165,184
let#centerleft 151 $ left node of centerbeam
let#pierright  165
let#addinside 1
let#ics1 711
let#not  731 $ number of first tendon
let#nrloc 1
#include extern    $ ICS1 711
#include extern    $
#include extern    $
#include extern    $
#include extern    $
$
let#field 4
let#pierleft   165   $ piernodes:       119,138,165,184
let#centerleft 174 $ left node of centerbeam
let#pierright  184
let#addinside 0
let#ics1 711
let#not  741 $ number of first tendon
let#nrloc 1
#include extern    $ ICS1 711
#include extern    $
#include extern    $
#include extern    $
ENDE

!#!KAPITEL Analysis
+prog csm urs:6
KOPF
STEU EG  AUTO  $ deadload applied automatically
STEU SPEI 0 $ no 7000 AQB stresses necessary (compute long)
$ ECHO CREP 245 $ shows the development of the
                $ construction stages in a good overview in the .lst file
$
STEU TEST 1 W2 200 W3 0 $ Test. only calculate 1:200 without creep
                        $ - ASE-AQB runs take too long with C+S
BA  1 TYP G_1 BEZ 'Piers'
BA  5 TYP C_1 BEZ 'Creep 50 days'               T    50
BA 10 TYP G_1 BEZ 'Pier table'
BA 11 TYP P   BEZ 'Prestress'
  BA 15 TYP C_1 BEZ 'Creep 50 days'               T    50
$ free cantilever erection:
let#cs 20
#define csm1
$  cs #cs-1 type  B TITL 'formtraveler #1'   - switched off to get quicker results
  BA #cs   TYP G_1 BEZ 'dead load CS #1'
  BA #cs+5 TYP C_1 BEZ 'Creep 14 d'              T    14
#enddef
#include csm1
let#cs 30
#define csm3
$  cs #cs-1 type  B TITL 'formtraveler #1'   - switched off to get quicker results
  BA #cs   TYP G_1 BEZ 'dead load CS #1'
  BA #cs+1 TYP P   BEZ 'Prestress CS #1'
  BA #cs+5 TYP C_1 BEZ 'Creep 14 d'              T    14
#enddef
#include csm3
let#cs 40
#include csm1
let#cs 50
#include csm3
let#cs 60
#include csm1
let#cs 70
#include csm3
let#cs 80
#include csm1
let#cs 90
#include csm3
let#cs 100
#include csm1
let#cs 110
#include csm3
let#cs 120
#include csm1
let#cs 130
#include csm3
let#cs 140
#include csm1
let#cs 150
#include csm3
let#cs 160
#include csm1
let#cs 170
#include csm3
let#cs 180
#include csm1
let#cs 190
#include csm3
let#cs 200
#include csm1
let#cs 210
#include csm3
let#cs 220
#include csm1
let#cs 230
#include csm3
$
$ close the cap : midspan span 3
let#cs 410
#include csm3
$ close the cap :  span 1+5
let#cs 510
#include csm3
$ close the cap :  span 2+4
let#cs 610
#include csm3
$ add  external prestress
let#cs 710
#include csm3
$
$ add  additional deadload
$ cs 790 type G_2 TITL 'additional deadload'
BA 801 TYP C_1 BEZ 'C+S trafic open'              T   100
BA 802 TYP C_2 BEZ 'C+S t-infinite'               T 365*100   NKRI 5
$ -----------------------------------------------------------------
let#1 19 $ piernodes:       119,138,165,184
let#2 38
let#3 65
let#4 84
GRUP        IBA1 NR   PHIF=1
              1  0
             10  17,18,19,20
             10  36,37,38,39
             10  63,64,65,66
             10  82,83,84,85
let#n 2 ;    20  #1+#n,#2+#n,#3+#n,#4+#n $ cantilever on the right
let#n 3 ;    30  #1-#n,#2-#n,#3-#n,#4-#n $ cantilever on the left
             40  #1+#n,#2+#n,#3+#n,#4+#n $ cantilever on the right
let#n 4 ;    50  #1-#n,#2-#n,#3-#n,#4-#n $ cantilever on the left
             60  #1+#n,#2+#n,#3+#n,#4+#n $ cantilever on the right
let#n 5 ;    70  #1-#n,#2-#n,#3-#n,#4-#n $ cantilever on the left
             80        #2+#n,#3+#n       $ cantilever on the right
let#n 6 ;    90        #2-#n,#3-#n       $ cantilever on the left
            100        #2+#n,#3+#n       $ cantilever on the right
let#n 7 ;   110        #2-#n,#3-#n       $ cantilever on the left
            120        #2+#n,#3+#n       $ cantilever on the right
let#n 8 ;   130        #2-#n,#3-#n       $ cantilever on the left
            140        #2+#n,#3+#n       $ cantilever on the right
let#n 9 ;   150        #2-#n,#3-#n       $ cantilever on the left
            160        #2+#n,#3+#n       $ cantilever on the right
let#n 10;   170        #2-#n,#3-#n       $ cantilever on the left
            180        #2+#n,#3+#n       $ cantilever on the right
let#n 11;   190        #2-#n,#3-#n       $ cantilever on the left
            200        #2+#n,#3+#n       $ cantilever on the right
let#n 12;   210        #2-#n,#3-#n       $ cantilever on the left
            220        #2+#n,#3+#n       $ cantilever on the right
let#n 13;   230        #2-#n,#3-#n       $ cantilever on the left
$
            410         51
            510         (1  13 1)
            510        (89 101 1)
            610         24,78
$
GRUP NR       IBA1  WBIS $ ATIL=activ til:
   201       10    609  $ temporary fixing short piers
$
$ LC    no     TYPE  ICS1      ATIL   $ only additional loads
$       2      G_2   790

$ Precamber analysis:  zero-target-stage = CS 801 - traffic opening
$ In a linear analysis the precamber has no effect on the forces. Thus
$ the deformations of the loadcases 4000.. can directly be modified. For checks a copy of
$ the original 4000.. loadcases is made in loadcases 14000...
UEBE BA 801 MODE LINE
$
AUSW STAB 390 X 0[m]        $ BEAM element for AQB stress print
BOX ZMIN -99 ZMAX -10    $ Plot without column
ENDE

$ Dann die Datei $(NAME)_csm.dat  laufen lassen
$ Wird hier automatisch über +apply erledigt
+apply "$(NAME)_csm.dat"

$ Dateiordner aufräumen:
+sys del $(project).$d?

