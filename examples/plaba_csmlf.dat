$ *************************************************************
$
$ MAXIMA-Block fuer Einwirkung ACT GPC (5000-er Lastf瓣lle):
$ Zu verwenden im MAXIMA z.B.:
$     [$(project)_csmlf.dat ist vor MAXIMA zu includieren]
$     [damit die max_act_g Bl繹cke definiert sind,]
$     [am besten nach einem zweifachen "ENDE"
$                                      "ENDE"
$      vgl. csm.dat\deutsch\more\csm31_design_maxi.dat ]:
$
$ ENDE
$ ENDE
$ #include "$(project)_csmlf.dat"
$ PROG MAXIMA
$ KOPF
$   KOMB  .. desi BASE ..
$     ACT G
$       #include max_act_g
$                (oder getrennt G_1 G_2 verwendbar)
$     ACT P
$       #include max_act_p  $ or   m_p_infsup
$     ACT C
$       #include max_act_c
$
#define max_act_g
      LF  5010 ;  5030
#enddef
$
$                 getrennt G_1 G_2 ... :
#define maxactg_1
      LF  5010
#enddef
$
#define maxactg_2
      LF  5030
#enddef
$
#define max_act_p
      LF  5011 ;  5021
#enddef
$
#define m_p_infsup
      LF  5011 G     0.900 ;  5011 Q     0.200
      LF  5021 G     0.900 ;  5021 Q     0.200
#enddef
$
#define max_act_c
      LF  5015 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5035 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5045 TYP   Q $ K+S nach Verkehrsuebergabe wahlweise
      LF  5046 TYP   F $ wenn K+S bis t-oo, dann alle
#enddef
