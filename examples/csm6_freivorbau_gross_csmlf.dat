$ *************************************************************
$
$ MAXIMA-Block fuer Einwirkung ACT GPC (5000-er Lastfälle):
$ Zu verwenden im MAXIMA z.B.:
$     [$(project)_csmlf.dat ist vor MAXIMA zu includieren]
$     [damit die max_act_g Blöcke definiert sind,]
$     [am besten nach einem zweifachen "ENDE"
$                                      "ENDE"
$      vgl. csm.dat\deutsch\more\csm31_design_maxi.dat ]:
$
$ ENDE
$ ENDE
$ #include "$(project)_csmlf.dat"
$ PROG MAXIMA
$ KOPF
$   KOMB  .. desi BASE ..
$     ACT G
$       #include max_act_g
$                (oder getrennt G_1 G_2 verwendbar)
$     ACT P
$       #include max_act_p  $ or   m_p_infsup
$     ACT C
$       #include max_act_c
$
#define max_act_g
      LF  5001 ;  5010 ;  5020 ;  5030 ;  5040 ;  5050 ;  5060 ;  5070 ;  5080
      LF  5090 ;  5100 ;  5110 ;  5120 ;  5130 ;  5140 ;  5150 ;  5160 ;  5170
      LF  5180 ;  5190 ;  5200 ;  5210 ;  5220 ;  5230 ;  5410 ;  5510 ;  5610
      LF  5710
#enddef
$
$                 getrennt G_1 G_2 ... :
#define maxactg_1
      LF  5001 ;  5010 ;  5020 ;  5030 ;  5040 ;  5050 ;  5060 ;  5070 ;  5080
      LF  5090 ;  5100 ;  5110 ;  5120 ;  5130 ;  5140 ;  5150 ;  5160 ;  5170
      LF  5180 ;  5190 ;  5200 ;  5210 ;  5220 ;  5230 ;  5410 ;  5510 ;  5610
      LF  5710
#enddef
$
#define max_act_p
      LF  5011 ;  5031 ;  5051 ;  5071 ;  5091 ;  5111 ;  5131 ;  5151 ;  5171
      LF  5191 ;  5211 ;  5231 ;  5411 ;  5511 ;  5611 ;  5711
#enddef
$
#define m_p_infsup
      LF  5011 G     0.900 ;  5011 Q     0.200
      LF  5031 G     0.900 ;  5031 Q     0.200
      LF  5051 G     0.900 ;  5051 Q     0.200
      LF  5071 G     0.900 ;  5071 Q     0.200
      LF  5091 G     0.900 ;  5091 Q     0.200
