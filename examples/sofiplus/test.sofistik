    <task>
     <name>Berechnung Einzellastfälle</name>
     <function id="9" internal_id="14" open="0" state="2">calculation::sof_analysis_dll</function>
     <file>$ Automatisch generiert von ASE 2026-3.0 24.03.2026 17:12
$ Achtung: Änderungen werden bei Neuaufruf eines Tasks überschrieben!
+PROG ASE urs:9 $ Berechnung Einzellastfälle
KOPF Berechnung von Schnittkräften
SEIT UNIE 0
STEU OPT WARP WERT 0
LF ALLE
ENDE
+PROG WING urs:9.1 $ Grafische Ausgabe
KOPF Grafische Ausgabe
SEIT UNIE 0
STEU LEER JA          $ leere Bilder erzeugen, wenn angeforderte Ergebnisse nicht darstellbar sind
STEU WARN (800 802 1) $ keine Warnungen, wenn angeforderte Ergebnisse nicht darstellbar sind
STEU WARN (804 808 1) $ keine Warnungen, wenn angeforderte Ergebnisse nicht darstellbar sind
STEU WARN 873         $ keine Warnung wegen 2D Sichtbarkeit
#define SCHR=0.2
SCHR H6 0.2
#define FILL=-
#define FILLI=-
#define FILLC=-
#define SCHRI=-
#define SCHRC=-
BEOB EGXY    $ Blick in die globale Z-Richtung
MOVE UNIT PRWC X  0 Y 33 DTYP QSCH ; DRAW UNIT PRWC X 100 Y  33 DTYP QSCH $ Schnitt in X-Richtung
MOVE UNIT PRWC X  0 Y 66 DTYP QSCH ; DRAW UNIT PRWC X 100 Y  66 DTYP QSCH $ Schnitt in X-Richtung
MOVE UNIT PRWC X 33 Y  0 DTYP QSCH ; DRAW UNIT PRWC X  33 Y 100 DTYP QSCH $ Schnitt in Y-Richtung
MOVE UNIT PRWC X 66 Y  0 DTYP QSCH ; DRAW UNIT PRWC X  66 Y 100 DTYP QSCH $ Schnitt in Y-Richtung
SIZ2 TEIL BILD
SIZE -URS M 0 TEIL  2x1 RAND NEIN FORM STAN
BEOB EG3
LF 1 BEME 1
LAST TYP ALLE
KNOT TYP AV SCHR JA
KNOT TYP RZ SCHR JA
BEOB EGX
KNOT TYP UZ FILL $(FILLI) SCHR $(SCHRI) DARS DHOH
BEOB EG3
VERS TYP VOLL FAK STAN LF AKTU; STRU NUME 0 0; VERS NEIN
BEOB EGX
QUAD TYP  HM SCHR NEIN DARS DVEK
ENDE
</file>
     <dlgdata name="calculation">
      <page name="Calc"/>
     </dlgdata>
    </task>
   </tasks>
