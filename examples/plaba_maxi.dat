+PROG WING urs:mwing81
KOPF Spannungen der Ueberlagerungskombinationen linear Pm_1.0
#define WINGDATA
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  SEIT UNIA 2   $ Einheiten = Hochbau Momente in kNm ...
  SIZE -urs M  100 Teil 3x1 hleg -1.5 tleg 1.5 $ Teil 3x1=3 Teilbilder über die Höhe $ urs = Querformat -urs = Hochformat
  SIZ2 UMBR AB
  BEOB EG3           $ Blickrichtung  3D
  grup - ja
  grup ausr,auns,astr,alan,ageo nein $ keine Achsen
  farb f25 0 ; farb f31 0 $ keine Spannstränge
  farb f16 0 ; $ Randelemente
  farb f23 0 ; farb f24 0 $ SIR-Schnitte
  grup - nein QUAD,RAND,FEDE
  BOX xmin ymin zmin  xmax ymax zmax $ BOX bei Bedarf
  STEU MESS 2D
  let#schr 0.27 ; SCHR H6 #schr $ Schrifthöhe
  $ Einheitliche Massstäbe für:
  let#fact_U        50 $ Überhöhung der Verformung
  let#beam_MY    50000 $ Massstab Momente    an Stäben
  let#beam_N     50000 $   " Normalkräfte    an Stäben
  let#quad_m      5000 $   " Biegemomentes   an quads
  let#quad_n      5000 $   " Normalkräfte    an quads
  let#quad_sig   10.00 $   " Spannungen      an quads  N/mm2
  let#quad_as   50.00 $   " Bewehrung       an Quadschnitten cm2/m
  let#beam_sig   10.00 $   " Spannungen      an Stäben N/mm2
  und 1 msca nein    $ Zentrierung Bilder auf Systemgrenzen
  schr prue 0        $ Schriftprüfung - wenig Überschreibungen
  sch2 MIN1 STAN MAX1 STAN $ Schriftwerte zurücksetzen
  STEU LEER JA       $ falls BEMESS Fehler - andere Werte plotten
#enddef
#define WING_CUT
$
  grup - ja
  grup - nein RAND,FEDE
move         $ erzeuge einen QUAD-Schnitt bei y=:
  grup - ja
@KEY 10 0; LET#xmin @7  ; LET#ymin @8
           LET#xmax @10 ; LET#ymax @11
         $ xmin,ymin,xmax,ymax aus der .CDB gelesen
LET#yy 0.25*#ymin+0.75*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
LET#yy 0.50*#ymin+0.50*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
LET#yy 0.75*#ymin+0.25*#ymax ; MOVE X #xmin Y #yy; DRAW X #xmax Y #yy DTYP zz
         $ Schnitt in X-Richtung bei y=#yy m
$
#enddef
#define WINGBOXGRP
$
GRUP - nein
  GRUP   1
  GRUP   2
  GRUP   3
#enddef
#include WINGDATA
#include WING_CUT
#include WINGBOXGRP
  SIZE  urs M    0 Teil 2x1 hleg -1.5 tleg 1.0
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Max-min Spannung Zustand I Kombination charakteristisch (selten) oben
LF  1121 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1122 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT unten
LF  1121 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1122 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
$ -------------------------
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Max-min Spannung Zustand I Kombination freq Pm_1.0 oben
LF  1321 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1322 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT unten
LF  1321 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1322 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
$ -------------------------
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Max-min Spannung Zustand I Kombination perm Pm_1.0 oben
LF  1421 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1422 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT unten
LF  1421 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1422 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
$ -------------------------
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT Max-min Spannung Zustand I Kombination 1.0_ oben
LF  1921 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1922 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNO UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  MOVE X DEL DTYP TEXT ; MOVE X 1 18 UNIT PR SCHR .30 F 1001 DTYP TEXT
TEXT unten
LF  1921 ; SCH2 MIN1 0 MAX1 999999
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
  und ; LF  1922 ; SCH2 MIN1 -999999 MAX1 0
  DSGN TYP LINE DTYP Z $ Spannungen am Schnitt->Z
  QUAD SNU UNIT #quad_sig ND 2 DARS DCUT SCHR #schr STYP E2K
$ -------------------------
ENDE
