let#h(176)    $(h176)
let#h(177)    $(h177)
#enddef
#include seth

let#field 1
let#centerleft 110 $ left node of centerbeam
let#ics1 511
let#not  511 $ number of first tendon
let#nrloc 1
#define bottom
  $ let#0 2
  let#node1 #centerleft-#nrloc-1 $ starting node of tendon
  let#node2 #centerleft+#nrloc+2 $ ending   node of tendon
  let#beam1 (#node1-100)*10   $ starting beam of tendon
  let#beam2 (#node2-100-1)*10 $ ending   beam of tendon
  let#center (#centerleft-100)*10 $ centerbeam-startpoint of tendon
  SGEO NRG #not NRH 1 NRSV 2
  ZPUV  S        X      U      V        DVS  TYP=STAB
       #beam1    0.000  0.000  #h(#node1)-0.700
       #beam1+10 0.000  0.000  #h(#node1+1)-0.250
       #beam1+20 0.000  0.000  #h(#node1+2)-0.200
     if #node2-#node1>5
       #beam1+30 0.000  0.000  #h(#node1+3)-0.200
       #beam2-20 0.000  0.000  #h(#node2-3)-0.200
     endif
       #beam2-10 0.000  0.000  #h(#node2-2)-0.200
       #beam2    0.000  0.000  #h(#node2-1)-0.250
       #beam2+10 0.000  =      #h(#node2)-0.700
  VSIG 'RE' ANWS 9 KAPA 1.5 K3 1280 $ kapa = Vorhaltemass Überspannreserve DIN-FB 4.2.3.5.4
  CS IBA1 #ics1 #ics1+1
  TEND #not NRG #not NSP 2 LF #ics1 BEZ 'bottomfield #field'
                      $   2 Attention: NSP=2
    #include tendonplot
  let#nrloc #nrloc+1
  let#not   #not+1
#enddef
#include bottom    $ ICS1 511
#include bottom    $
#include bottom    $
$
