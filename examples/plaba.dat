!#!Info  Beispiel:       Plattenbalkenphilosophie exzentrisch
!#!Info  Schlagwort:     Plattenbalkenphilosophie
!#!Info  Program:       CSM
$
$

!#!KAPITEL Material and System generation
+PROG AQUA urs:1
KOPF Plattenbalkenbrücke exzentrisch
NORM  'DIN' 'en199X-200X-BRIDGE'     CAT 'B'    $ Strassenbrücken -> L_U + L_T gammau = 1.35 !
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
$ CTRL styp BEM
ECHO MAT,QUER VOLL
!*!Label Material
BETO  1    C    40  $ = C40/50
STAH  2    S 500    $ Bewehrungsstahl 500
STAH  7    S  '235' $ TMAX  0 $ Baustahl
STAH 11    Y '1860A' $ prestessing steel
                    $ fp0,1k = 1600 N/mm2
                    $ fpk    = 1860 N/mm2
                    $            0.8*fpk    = 0.80*1860 = 1488 N/mm2
                    $            0.9*fp0,1k = 0.90*1600 = 1440 N/mm2
                    $ sigp,max = min(1488,1440)         = 1440 N/mm2 EN-1992-1-1 5.10.2.1(1) maximale Spannung
                    $ sigp,SLS = 0.65*fpk   = 0.65*1860 = 1209 N/mm2 EN-1992-1-1 7.2(5)      bei Verkehrsübergabe quasiständig
                    $ sigp,rare= sigp,max
                    $ Die Spannstahlrelaxation sollte bei ca 1280 N/mm2 Vorspannung betragen:
                    $ Verlust nach 1000h   : ca. 2 %
                    $ Verlust t-undendlich : ca. 6 %
                    $ vgl. Beispiele zur Bemessung nach Eurocode 2 Band 2 – Fertigteilbrücke
STAH 12    Y '1860A' $ prestessing steel

!*!Label  Section 1
QNR  1 MNR  1
#define section
QPOL  UPZ MNR 1
QP NR    Y        Z    EXP
     1  0.00[m] 0.00[m] 0.50 $ Belüftung nur über Asphalt
     2 -3.00[m] 0.00[m] 1.00 $ für alle folgenden QP !
     3 -3.00[m] 0.25[m]
     4 -2.50[m] 0.25[m]
     5 -0.80[m] 0.45[m]
     6 -0.80[m] 1.80[m]
let#zmax   1800 $ mm
$
$  Torsionsbox:  *---------------------> y
$                |
$     *----------|----------*     #ztop
$     |          |<--#ytop->|
$     |          |          |
$     |          |          |
$     |          |<--#ybot->|
$     *----------|----------*     #zbot
$                z
  let#ytop  720 $ [mm] y-Wert der Torsionsbox oben
  let#ybot  720 $ [mm] y-Wert der Torsionsbox unten
  let#ztop  110 $ [mm] z-Wert der Torsionsbox oben
  let#zbot #zmax-110 $ " der Torsionsbox unten  "       of Torsionsbox below
RANG 0 'TORS' TYP MIN $ Voreinstellung für Bewehrungsränge
RANG 1 'BOT'  TYP OPT $ untere Bewehrung 'bot' 'bot'
RANG 2 'TOP'  TYP OPT $ obere  Bewehrung 'top' 'top'
BEW Y #ytop,-#ytop Z #ztop AS 10[cm2] RANG 0 TORS AKTI D  12
BEW Y #ybot,-#ybot Z #zbot AS 10[cm2] RANG 0 TORS AKTI D  12
$ Biegebewehrung:
  let#ytop 2500 $ [mm]
  let#ybot  650 $ [mm]
  let#ztop   70 $ [mm]
  let#zbot #zmax-70
BEW Y #ytop,#ytop/3,-#ytop/3,-#ytop Z #ztop AS 10[cm2] RANG 2 TORS PASS D  20 $ oben
BEW Y #ybot,#ybot/3,-#ybot/3,-#ybot Z #zbot AS 10[cm2] RANG 1 TORS PASS D  20 $ unten
QS 1 ZA  450    MNR 1        RANG 1 $ Bei x=3.80 m von der Stütze oberhalb  Spannglied
QS 2 ZA  700    MNR 1        RANG 1 $ Bei x=3.80 m von der Stütze unterhalb Spannglied
QS 3 YA  820    MNR 1        RANG 3 TYP GURT  $ Gurt
STEU WARN 10463
QSP    NR    Y        Z     MNR
     'TOP'   0        0      1
     'BOT'   0       #zmax   1 $ Literal BOT muss in Grossbuchstaben eingegeben werden
     'SIDE' 3000[mm] #zmax   1 $ nichtmitwirkender Teil
#enddef
#include section
NEFF YMIN -9000 YMAX -2900  ZMIN -1000 ZMAX +9000 TYPE Z
NEFF YMIN  2900 YMAX  9000  ZMIN -1000 ZMAX +9000 TYPE Z

QNR  2 MNR  1   $ Nichtmitwirkende Breite über der Stütze
#include section
NEFF YMIN -9000 YMAX -1850  ZMIN -1000 ZMAX +9000 TYPE Z
NEFF YMIN  1800 YMAX  9000  ZMIN -1000 ZMAX +9000 TYPE Z


!*!Label Section 5
QNR  5 MNR  1  BEZ 'Querträger Endauflager'
let#bslab05 1.00 ; let#bweb05 0.80
#define crossgirder
QPOL  UPZ MNR 1
QP NR    Y        Z    EXP
     1  0.00[m] 0.00[m] 0.50 $ Belüftung nur über Asphalt
     2 -#bslab05[m] 0.00[m] 1.00 $ für alle folgenden QP !
     3 -#bslab05[m] 0.35[m]
     5 -#bweb05[m]  0.35[m]
     6 -#bweb05[m]  2.00[m]
let#zmax   2000 $ mm
$
$  Torsionsbox:  *---------------------> y
$                |
$     *----------|----------*     #ztop
$     |          |<--#ytop->|
$     |          |          |
$     |          |          |
$     |          |<--#ybot->|
$     *----------|----------*     #zbot
$                z
  let#ytop  720 $ [mm] y-Wert der Torsionsbox oben
  let#ybot  720 $ [mm] y-Wert der Torsionsbox unten
  let#ztop  110 $ [mm] z-Wert der Torsionsbox oben
  let#zbot #zmax-110 $ " der Torsionsbox unten  "       of Torsionsbox below
RANG 0 'TORS' TYP MIN $ Voreinstellung für Bewehrungsränge
RANG 1 'BOT'  TYP OPT $ untere Bewehrung 'bot' 'bot'
RANG 2 'TOP'  TYP OPT $ obere  Bewehrung 'top' 'top'
BEW Y #ytop,-#ytop Z #ztop AS 10[cm2] RANG 0 TORS AKTI D  12
BEW Y #ybot,-#ybot Z #zbot AS 10[cm2] RANG 0 TORS AKTI D  12
$ Biegebewehrung:
  let#ytop  900 $ [mm]
  let#ybot  650 $ [mm]
  let#ztop   70 $ [mm]
  let#zbot #zmax-70
BEW Y #ytop,#ytop/3,-#ytop/3,-#ytop Z #ztop AS 10[cm2] RANG 2 TORS PASS D  20 $ oben
BEW Y #ybot,#ybot/3,-#ybot/3,-#ybot Z #zbot AS 10[cm2] RANG 1 TORS PASS D  20 $ unten
QS 1 ZA  370    MNR 1        RANG 1 $ Bei x=3.80 m von der Stütze oberhalb  Spannglied
QS 2 ZA  900    MNR 1        RANG 1 $ Bei x=3.80 m von der Stütze unterhalb Spannglied
STEU WARN 10463
QSP    NR    Y        Z     MNR
     'TOP'   0        0      1
     'BOT'   0       #zmax   1 $ Literal BOT muss in Grossbuchstaben eingegeben werden
#enddef
#include crossgirder

QNR  6 MNR  1  BEZ 'Querträger Mittelauflager'
let#bslab05 1.40 ; let#bweb05 1.00
#include crossgirder

!*!Label Section 9
QB 9 H 1.5[m] B 4[m] BEZ 'Pfeiler'

QNR 99 MNR  1 BEZ 'Testquerschnitt für ex_q'
QPOL  UPZ MNR 1
QP NR    Y        Z    EXP
     1  0.00[m] 0.00[m] 0.50 $ Belüftung nur über Asphalt
     2 -3.00[m] 0.00[m] 1.00 $ für alle folgenden QP !
     3 -3.00[m] 0.25[m]
     4 -2.50[m] 0.25[m]
     5 -0.80[m] 0.45[m]
ENDE

+PROG AQUA urs:2
KOPF Plot sections
STEU REST 3
STEU WARN 10463
ECHO MAT NEIN ; ECHO QUER JA ; ECHO PICT VOLL
ENDE

+PROG RESULTS urs:7
KOPF Plot sections
SIZE DINA "URS"
LF QNR 2 ; STRU TYP CROS
ENDE

+PROG SOFIMSHA urs:4
KOPF Plattenpalkenbrücke exzentrisch
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
SYST RAUM GDIR POSZ GDIV 1000
KNOT  1 X  0   6 0 $ linke untere Ecke der Platte $
KNOT 13 X  8  -6 0 $ linke obere  Ecke der Platte $
sto#dxdy 8/12 $ dx/dy Brückenwinkel für Verkehrslasten $
KNOT NR NR1 NR2    Y
      2   1  13   5.50 $ Kante der Voute          $
      3   1  13   3.80 $ Stegkante                $
      4   1  13   3.00 $ Stabmitte                $
      5   1  13   2.20 $ Stegkante                $
      6   1  13   0.50 $ Kante der Voute          $
      7   1  13   0.00 $ Brückenmitte             $
      8   1  13  -0.50 $ Kante der Voute          $
      9   1  13  -2.20 $ Stegkante                $
     10   1  13  -3.00 $ Stabmitte                $
     11   1  13  -3.80 $ Stegkante                $
     12   1  13  -5.50 $ Kante der Voute          $
TRAN KNOT VON 1 BIS 13 DNR 100 DX 1.00
TRAN KNOT VON 1 BIS 13 DNR 200 DX 1.00+25.0
TRAN KNOT VON 1 BIS 13 DNR 300 DX 1.00+30.0
TRAN KNOT VON 1 BIS 13 DNR 400 DX 1.00+30.0+5.0
TRAN KNOT VON 1 BIS 13 DNR 500 DX 1.00+30.0+30.0
TRAN KNOT VON 1 BIS 13 DNR 600 DX 1.00+30.0+30.0+1.00
$
TRAN KNOT VON 104,304,504 DNR 1000 DZ 2.20  $ Pfeilerkopf
TRAN KNOT VON 107,307,507 DNR 1000 DZ 2.20
TRAN KNOT VON 110,310,510 DNR 1000 DZ 2.20
TRAN KNOT VON 107,307,507 DNR 2000 DZ 8.00  $ Pfeiler unten

KNOT 2107,2307,2507 FIX F

let#1 250 $ Dicke am Kragarmende                 $
let#2 450 $ Dicke am Kragarmanschnitt            $
let#3 450 $ dicker Plattenbereich                $
GRUP 3 BEZ 'Platte'
let#k 0 ; let#m  1
#define slab
QUAD K1     K2     K3     K4      M  N T1 T2 T3 T4 MNR=1 MBW=2 LAGE=UNTE
      1+#k 101+#k 102+#k   2+#k  #m  1 #1 #1 #1 #1 $ Kragarm   $
      2+#k 102+#k 103+#k   3+#k  #m  2 #1 #1 #2 #2 $ Voute     $
      3+#k 103+#k 104+#k   4+#k  #m  1 #3 #3 #3 #3 $ Steg      $
      4+#k 104+#k 105+#k   5+#k  #m  1 #3 #3 #3 #3 $ Steg      $
      5+#k 105+#k 106+#k   6+#k  #m  2 #2 #2 #1 #1 $ Voute     $
      6+#k 106+#k 107+#k   7+#k  #m  1 #1 #1 #1 #1 $ Kragarm   $
      7+#k 107+#k 108+#k   8+#k  #m  1 #1 #1 #1 #1 $ Kragarm   $
      8+#k 108+#k 109+#k   9+#k  #m  2 #1 #1 #2 #2 $ Voute     $
      9+#k 109+#k 110+#k  10+#k  #m  1 #3 #3 #3 #3 $ Steg      $
     10+#k 110+#k 111+#k  11+#k  #m  1 #3 #3 #3 #3 $ Steg      $
     11+#k 111+#k 112+#k  12+#k  #m  2 #2 #2 #1 #1 $ Voute     $
     12+#k 112+#k 113+#k  13+#k  #m  1 #1 #1 #1 #1 $ Kragarm   $
#enddef
#include slab
let#k 100 ; let#m 12
#include slab
let#k 200 ; let#m  4
#include slab
let#k 300 ; let#m  4
#include slab
let#k 400 ; let#m 12
#include slab
let#k 500 ; let#m  1
#include slab

GRUP 1 BEZ 'Überbau Stäbe Feldbereich'
  STAB fit KA   4 KE 204 QNR 1 NP -1
  STAB fit KA 404 KE 604 QNR 1 NP -1
  STAB fit KA  10 KE 210 QNR 1 NP -1
  STAB fit KA 410 KE 610 QNR 1 NP -1
GRUP 2 BEZ 'Überbau Stäbe Stützbereich'
  STAB fit KA 204 KE 404 QNR 2 NP -1
  STAB fit KA 210 KE 410 QNR 2 NP -1

GRUP 5 BEZ 'Querträger Endauflager'
  STAB fit KA 102 KE 112 QNR 5 NP -1
  STAB fit KA 502 KE 512 QNR 5 NP -1
GRUP 6 BEZ 'Querträger Mittelauflager'
  STAB fit KA 302 KE 312 QNR 6 NP -1

GRUP 9 BEZ 'Pfeiler'
  STAB fit KA 1107 KE 2107 QNR 9 NP 0 KR 101
  STAB fit KA 1307 KE 2307 QNR 9 NP 0 KR 301
  STAB fit KA 1507 KE 2507 QNR 9 NP 0 KR 501

KNOT 1104,1110 FIX kf 1107
KNOT 1304,1310 FIX kf 1307
KNOT 1504,1510 FIX kf 1507

GRUP 10 BEZ 'vertikale Lagerung'
  let#ne 104 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1
  let#ne 110 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1
  let#ne 304 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1
  let#ne 310 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1
  let#ne 504 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1
  let#ne 510 ; FEDE KA #ne+1000 KE #ne CP 1E7 CQ 1

GRUP 11 BEZ 'Horizontale Lagerung'
  let#ne 304 ; FEDE KA #ne+1000 KE #ne CP 1E6 DX 1
  let#ne 304 ; FEDE KA #ne+1000 KE #ne CP 1E6 DY 1
  let#ne 104 ; FEDE KA #ne+1000 KE #ne CP 1E6 DY 1
  let#ne 504 ; FEDE KA #ne+1000 KE #ne CP 1E6 DY 1
ENDE

+PROG SOFIMSHC urs:5
KOPF Achse für SOFILOAD Lastenzüge, SSD Tendons, Animator Umwelt
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
SYST REST
GAX 'AX_1'
GAXB X1 0 0 0 X2 100 0 0  $ create axis from point 1 to point 2   (also with R)
$ GAX...TYPC SPLI and GAXC can create an axis through a set of points
ENDE
!+!Kapitel Define Excentric T-beam philosophy !!!!!!!!!!!!!!!!!!!
+PROG ASE urs:3
KOPF T-beam philosophy definition
PLEX NRG AUTO $ Activates T-beam philosophy 2020 also for excentric beam elements - cathes also group 5+6 cross girderes
PLEX NRG 1  NEFF 0.01 $ Überbau Stäbe Feldbereich
PLEX NRG 2  NEFF 0.22 $ Überbau Stäbe Stützbereich
       $ Die NEFF verwendet man um die Momente über der Stütze zu skalieren:
       $ dazu am besten immer LF 8+9 rechnen (9=Stäbe ohne Platte : 8=PLEX) und dann:
       $ ein größeres NEFF      im  Feld   vermindert Stab-Feldmoment  in LF 8
       $ ein größeres NEFF über der Stütze vermindert Stab-Stützmoment in LF 8
       $ Alle anderen Parameter am besten nicht anfassen, es sei denn man erhält eine Instabilität,
       $ dann evtl. F_GZ verringern.

       $  YOUTUBE Video  ->   https://youtu.be/GoT1f0aGdgs         SOFiSTiK T-beam philosophy    How to model a T-beam or composite beam


             $ Der Faktor neff berücksichtigt, dass die Druckzwiebel in der Quadplatte
             $ nicht sofort und vollständig bis zum Rand ausstrahlen kann und daher der
             $ außenliegende Bereich der Platte nicht voll wirksam ist, besonders an Innenstützen.
             $ Dies entspricht dem Effekt der mitwirkenden Breite.
             $ Betrachten Sie hierzu die Quad Hauptnormalkräfte in Lastfall 8 (Druckzwiebel).
             $ Der Faktor neff wurde hier mit den Testlastfällen 7 und 8 ermittelt
             $ wobei man die Stabmomente aus LF 7 und 8 vergleicht.
             $
             $ Nur falls die automatische Ermittlung der mittleren Quaddicke nicht stimmt (->Report Liste)
             $ kann man die genaue Quadfläche und Exzentrizität auch eingeben, z.B.
             $ PLEX NRG 1 area 2.16[m2] ex_q 0.188[m] neff 0.01
             $     (bitte area und ex_q immer mit Dimension eingeben)
             $ area 2.16[m2] und ex_q hier gewonnen aus dem Testquerschnitt 99
             $          = 2*(0.80*0.45+1.70*0.35+0.50*0.25)[m2]
             $ Zum Skalieren der Eigengewichtsmomente aber besser NEFF verwenden!
             $
             $ Wenn Ihnen diese Manipulationen nicht zusagen könnte man auch die Quadplatte
             $ ohne Normalkraftsteifigkeit laufen lassen (GRP2 3 QUEA 1E-6)
             $
             $ NEFF Definition siehe auch Testbeispiel plattenbalken_exzentrisch_test.dat
<TEXT>
Die Definition PLEX sollte wie hier in einem eigenen separaten ASE Lauf kurz nach der Systemdefinition erfolgen.
Alle folgenden ASE Läufe verwenden dann diese Einstellung ohne erneute PLEX Eingabe,
auch beim Aufruf über den CSM oder einen SSD Tasks (Eigenwerte Task).
</TEXT>
ENDE

+PROG SOFILOAD urs:8
KOPF
LF  9          BEZ 'Test beam load'  TYP none
   STAB GRP 1,2 TYP PZZ 100
ENDE
+PROG ASE URS:16
KOPF Vergleich reine Stabberechnung - evtl. Skalierung NEFF Eingabe in PLEX
GRUP - ; GRUP 3 NEIN
LF 7 TYP NONE BEZ 'Test Stablast nur mit Stabelementen'
  LC 9
ENDE
KOPF
GRUP - ; GRUP 3 JA
LF 8 TYP NONE BEZ 'Test Mit Quadplatte und PLEX'
  LC 9
ENDE      $ Bitte vergleichen Sie im WINGRAF die Stabmomente MY von LF 7 und LF 8
         $ und justieren dann NEFF bis die Momente gut übereinstimmen

!#!Kapitel Loading, Prestress
+PROG SOFILOAD URS:13
KOPF Einwirkungen und Lasten
$ Einwirkungsfaktoren :
$ Für alle Brueckenberechnungen sollten zunächst alle verwendeten Einwirkungen definiert werden.
$ Dies kann wie hier in einem separaten SOFILOAD Lauf erfolgen
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
ECHO ACT VOLL $ Bitte prüfen Sie die GAMU Werte. In Deutschland ist z.B. GAMU = 1.35 für L_U und L_T !
ACT G_1                                                              BEZ 'Ständige Lasten'
ACT G_2                                                              BEZ 'Ständige Lasten'
ACT P                                                            BEZ 'Vorspannung'
ACT C                                                                BEZ 'Kriechen+Schwinden'
ACT ZC  GAMU 1.00 1 SUP PERM PSI0 1.00 PSI1 1.00 PSI2 1.00           BEZ ''
ACT L_T GAMU   -  0 SUP EXCL PSI0 0.75 PSI1 0.75 PSI2 0.20 PS1S    - BEZ 'TS Tandemsystem'
ACT L_U GAMU   -  0 SUP EXCL PSI0 0.40 PSI1 0.40 PSI2 0.20 PS1S    - BEZ 'UDL Gleichlast'
  $ Verkehrbeanspruchung erfolgt mit ELLA - daher ist L_U EXCL erforderlich!
ACT SL  GAMU 1.50 0 SUP COND PSI0 0.40 PSI1 0.40 PSI2 0.20 PS1S    - BEZ 'Gleichlast'
$--------------------------------------------------------------------------
ACT FAT GAMU 1.50 0 SUP EXCL PSI0 1 1 1                              BEZ 'Ermüdung LM3'
ACT SF  GAMU 1.00 0 SUP EXCL PSI0 1 1 1                              BEZ 'mögl.Setzung ULS'
ACT ZF  GAMU 1.00 0 SUP EXCL PSI0 1 1 1                              BEZ 'wahrscheinliche Setzung SLS'
  $ Nach DIN FB 101 Anhang C.2.3 ist für Setzungen
  $ ein Lastsicherheitsbeiwert GAMA=1.00 anzusetzen.
ACT W                                                                BEZ 'wind transvers'
ACT T   GAMU 0.81 0 SUP EXCL PSI0 0.80 PSI1 0.60 PSI2 0.50 PS1S    - BEZ 'temperatur'
  $ Im Nachweis des Grenzzustandes der Tragfähigkeit können die Schnittgrößen aus Temperaturbelastung
  $ in der Regel mit 60 % Steifigkeit ermittelt werden. Man darf hier annehmen dass der Beton
  $ reißt und - da es eine Zwangsbelastung ist - die Schnittgröße durch die Rissbildung abfällt.
  $ Daher wird der Einfachheit halber der GZT-gamma-u Wert von 1.35 auf 0.81 gesetzt (0.81 = 1.35*0.60).
  $ also: Sicherheitsbeiwert 1.35 aber nur 0.6 fach wegen 60 % Steifigkeit
  $---------------------------------------------------------------------------------------------------------
ACT B   GAMU 1.35 1 PART G SUP PERM PSI0 1 1 1                              BEZ 'Bauzustand'
ENDE

+PROG TENDON urs:9
KOPF Evtl. alte Spannglieder löschen
VDEL 0 0 0
ENDE

+PROG TENDON urs:24
KOPF Parabelvorspannung
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
$ Definition des Spannverfahrens:
$ Wir empfehlen, alle Daten als benutzerdefiniertes Spannverfahrens
$ explizit einzugeben. Für die Statik sind folgende Werte ausreichend:
SYSP NRSV MAT   ZV       AZ    LITZ MINR   BETA  MUE EXZ  SS     DA
      $ 1  11 2430[kN] 1800[mm2] 12 6.50[m] 0.3 0.20 4[mm] 3[mm] 82[mm] $ csm3_parabel and csm32_slab, 12 wires
      $ 1  11 3078[kN] 2250[mm2] 15 7.10[m] 0.3 0.20 4[mm] 3[mm] 92[mm] $            15 wires
        1  11 3848[kN] 2850[mm2] 19 6.50[m] 0.3 0.21 4[mm] 3[mm] 97[mm] $ csm31_beam 19 wires
      $ 1  11 2430[kN] 1800[mm2] 12 6.50[m] 0.0 0.00 0[mm] 0[mm] 10[mm] $ csm3_casting_yard
$
$ reference axis and span definition:
let#tendon 1
AXES NRH #tendon TYP AUTO  4 604
HOCH NRH #tendon TYP KNOT S 104,304,504 SF 1,2,3
#define tend
                   $ S=104 .. SP 1 =  Node 104 is beginning first span
        $ tendon geometry definition:
        SGEO NRG #tendon NRH #tendon NRSV 1
        $ Definition points of geometry:  (TYP=SPAN/FELD station via highpoints)
        ZPUV    S     U     V   DVS    RV   RL   TYP=FELD
                0     0   0.5     -    -     -
              1.4     -   1.62    0    -     -
                2     0   0.16    0   12.5   2.8
              2.6     -   1.62    0    -     -
                4     0   0.5     -    -     -
        $ Additional values: construction stages:
        CS IBA1 11 12
        $ prestress-procedure  $ Anspann-Vorgehen
        VSIG 'RELI' ANWS 9 KAPA - K3 1280 $ kapa = Vorhaltemass Überspannreserve EN-1992-1-1 5.10.2.1
        $ final tendon definition:
        TEND NRS #tendon NRG #tendon NSP 3 LF 3 LF0 0
#enddef
#include tend
let#tendon 2
AXES NRH #tendon TYP AUTO 10 610
HOCH NRH #tendon TYP KNOT S 110,310,510 SF 1,2,3
#include tend
$
ECHO PLOT VOLL $ tendon plots:
SIZE URS
PLOT GEOA NR all FAKH  5 TYPG DUTE
PLOT FAKT NR 1 FAKH 15
ENDE

+PROG TENDON urs:23
KOPF Plattenquervorspannung
UNIT 5 $ Einheiten: Querschnitte in mm, Geometrie+Lasten in m
SYSP NRSV MAT   ZV       AZ    LITZ MINR   BETA  MUE EXZ  SS     DA
        2  12 1417[kN] 1050[mm2]  7 6.50[m] 0.3 0.20 4[mm] 3[mm] 76[mm]
$ reference axis 12 = gobal y-axis:
AXES NRH 12  VAL1  0.00  6.0 0.00  TYP=poly  ART=QUAD
         12  VAL1  0.00 -6.0 0.00  BEZ "tendon_axis 12"
let#tend_slab 101
let#x 8.50  $ X-coordinate of first tendon
#define tend12
SGEO NRG #tend_slab NRH 12 NRSV 2 $ NOPS = prestressing system for max-min radius parameters + duct-excentricities
ZPUV S    U    V   DVS TYP=REFX
      0  #x   0.125
      6  #x   0.125
     12  #x   0.125
CS IBA1 21 22                $ = construction stages
VSIG RE ANWS 'AS' KAPA - K3 1280
