      LF  5021 G     0.900 ;  5021 Q     0.200
  ACT C
      LF  5015 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5035 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5045 TYP   Q $ K+S nach Verkehrsuebergabe wahlweise
      LF  5046 TYP   F $ wenn K+S bis t-oo, dann alle
  ACT Y_1 GAMU 1 0 1 1 1 -
$ *************************************************************
                     $ End-ueberlagerung mit pkinf-pksup -> LF 9000...
KOMB 413 freq BASE - TYPE Y_X $ Kombination freq PK,inf-sup
  ACT G_1
      LF  5010
  ACT G_2
      LF  5030
  ACT P $ pk,sub, pk,inf -> e.g. 0.9-1.1:  0.9G+0.2Q
      LF  5011 G     0.900 ;  5011 Q     0.200
      LF  5021 G     0.900 ;  5021 Q     0.200
  ACT C
      LF  5015 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5035 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5045 TYP   Q $ K+S nach Verkehrsuebergabe wahlweise
      LF  5046 TYP   F $ wenn K+S bis t-oo, dann alle
  ACT Y_3 GAMU 1 0 1 1 1 -
                     $ End-ueberlagerung mit pkinf-pksup -> LF 9000...
KOMB 414 perm BASE - TYPE Y_X $ Kombination perm PK,inf-sup
  ACT G_1
      LF  5010
  ACT G_2
      LF  5030
  ACT P $ pk,sub, pk,inf -> e.g. 0.9-1.1:  0.9G+0.2Q
      LF  5011 G     0.900 ;  5011 Q     0.200
      LF  5021 G     0.900 ;  5021 Q     0.200
  ACT C
      LF  5015 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5035 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5045 TYP   Q $ K+S nach Verkehrsuebergabe wahlweise
      LF  5046 TYP   F $ wenn K+S bis t-oo, dann alle
  ACT Y_4 GAMU 1 0 1 1 1 -
$ *************************************************************
                     $ End-ueberlagerung Robustheit rare ohne p
KOMB 427 rare BASE - TYPE Y_X $ Kombination robust without p
  ACT G_1
      LF  5010
  ACT G_2
      LF  5030
  ACT C
      LF  5015 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5035 TYP  G $ K+S bis Verkehrsuebergabe = staendig
      LF  5045 TYP   Q $ K+S nach Verkehrsuebergabe wahlweise
      LF  5046 TYP   F $ wenn K+S bis t-oo, dann alle
  ACT Y_1 GAMU 1 0 1 1 1 -
                     $ End-ueberlagerung mit pkinf-pksup -> LF 9000...
KOMB 429 freq BASE - TYPE Y_X $ Kombination freq PK,inf-sup
  ACT G_1 GAMU 1 1 1 1 1 -
      LF  5010
  ACT G_2 GAMU 1 1 1 1 1 -
      LF  5030
  ACT P $ pk,sub ->loadcase..pk,sub permanent
      LF  5011 G     0.900 $ Fest mit einem Faktor, damit kein Beitrag zur Schwingbreite
      LF  5021 G     0.900 $ Fest mit einem Faktor, damit kein Beitrag zur Schwingbreite
  ACT C GAMU 1 1 1 1 1 -
      LF  5015 TYP  G $ K+S fest bis t-oo = staendig
      LF  5035 TYP  G $ K+S fest bis t-oo = staendig
      LF  5045 TYP  G $ K+S fest bis t-oo = staendig
      LF  5046 TYP  G $ K+S fest bis t-oo = staendig
  ACT Y_G GAMU 1 0 1 1 1 -
$ *************************************************************
ENDE
$ *************************************************************
