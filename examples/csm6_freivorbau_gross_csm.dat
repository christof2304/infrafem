ENDE
$
-PROG RESULTS urs:result1
KOPF Plot Check print Gesamtspannungen der Summenlastfälle
SIZE URS M  0
let#AQUP_sig     10000 $ 1 cm entspricht #AQUP_sig kN/m2
let#AQUP_sss     50000 $ Betonstahlspannungen
  STEU WARN 802,821 $ falls der Querschnitt keine Bewehrung hat kommt sonst eine Warnung
$
$ next element
LET#N       390 ; LET#x     0.000[m]
 BILD BEZ "CSM BA 1 Stab 390 x= 0.00 Piers"
 LF 7001 ENR #N x #x
        QUER TYP SIG ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN $ UNIT #AQUP_sig $ 1 cm = ... N/mm2
  und ; QUER TYP BWS ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN UNIT #AQUP_sss $ Betonstahlspannungen
 BILD BEZ "CSM BA 10 Stab 390 x= 0.00 Pier table"
 LF 7010 ENR #N x #x
        QUER TYP SIG ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN $ UNIT #AQUP_sig $ 1 cm = ... N/mm2
  und ; QUER TYP BWS ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN UNIT #AQUP_sss $ Betonstahlspannungen
 BILD BEZ "CSM BA 11 Stab 390 x= 0.00 Prestress"
 LF 7011 ENR #N x #x
        QUER TYP SIG ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN $ UNIT #AQUP_sig $ 1 cm = ... N/mm2
  und ; QUER TYP BWS ETYP STAB RTYP NONL SCHR 0.25 DARS DLIN FILL NEIN UNIT #AQUP_sss $ Betonstahlspannungen
