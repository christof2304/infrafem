$ *************************************************************
#define stage_design
$ Tabelle fuer Bemessung in Bauzustaenden - Beispiel siehe  csm34_stage_design.dat
$ Anwendung: Variable cs_design setzen, z.B. sto#cs_design 120
$ dann die GAMU defines setzen, z.B.:
$    #define GAMU_G_1=GAMU 1.35 GAMF 1.00   $  dead load       take sum of all effects of G_1 with 1.35 or 1.00
$    #define GAMU_G_2=GAMU 1.35 GAMF 1.00   $  add.dead        take sum of all effects of G_2 with 1.35 or 1.00
$    #define GAMU_P=GAMU 1.00 GAMF 1.00   $  prestress
$     creep is already defined in the #include stage_design
$ dann #include stage_design    setzen.
$ -> es werden damit nur die Lastfaelle gesetzt, die zu diesem Bauzustand gehoeren.
$    Diese koennen dann einfach mit z.B. KOMB ... LF1 G LF2 P LF3 C verwendet werden.
$    Dabei werden die entsprechenden Sicherheits- und psi-Beiwerte  gesetzt.
$
LET#LOOPSIZE 4999
$
if $(cs_design)>=010 ; LF 5010  TYP "G_1 "  QT   10 REF TEIL SUP PERM $(GAMU_G_1) ; endif
if $(cs_design)>=011 ; LF 5011  TYP "P   "  QT   11 REF TEIL SUP PERM APAR P $(GAMU_P) ; endif
if $(cs_design)>=015 ; LF 5015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=015 ; LF 6015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=021 ; LF 5021  TYP "P   "  QT   21 REF TEIL SUP PERM APAR P $(GAMU_P) ; endif
if $(cs_design)>=030 ; LF 5030  TYP "G_2 "  QT   30 REF TEIL SUP PERM $(GAMU_G_2)      ; endif
if $(cs_design)>=035 ; LF 5035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=035 ; LF 6035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=045 ; LF 5045  TYP "C_2 "  QT   45 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=045 ; LF 6045  TYP "C_2 "  QT   45 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=046 ; LF 5046  TYP "C_2 "  QT   46 REF TEIL SUP PERM GAMU 1 1         ; endif
if $(cs_design)>=046 ; LF 6046  TYP "C_2 "  QT   46 REF TEIL SUP PERM GAMU 1 1         ; endif
$ --------------------- Ende AQB Bemessung in Bauzustaenden - siehe  csm34_stage_design.dat ------------
#enddef
