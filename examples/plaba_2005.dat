$
#define project= "plaba"
$ ******************* Construction Stage Manager **************
$
$ Eine Übersicht über Lastfälle, Bauzustände, Gruppenparamter
$ sowie eine Zusammenstellung der Kriechbeiwerte ist in der
$ CSM-Ausgabedatei zu finden.
$
$ ******************* Construction Stage Manager **************
$PROG ASE
#define ASE_CTRL
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  ECHO vers,schn,nost,bett,last,reak,grup,lsum nein
  STEU DIFF 1000 $ Differenzlastfälle Inkrement
  STEU KRAG   12 $ 1 = Vorbau mit Ausgangsneigung
                 $ 2 = tangentialer Vorbau
#enddef
$
$PROG AQB
#define AQB_CTRL
  SEIT UNIE 0  ! Standard Eingabeeinheiten
  ECHO schn,komb,span,eige nein
  STEU EIGE 1+2+64
  STEU QWF   1.00000 $ Berücksichtigung der Bewehrung bei K+S
  STEU VM   VAL2 1.0 $ Längskraft delta-N infolge Torsion in der Biegebemessung BEME berücksichtigen
#enddef
$
#define AQB_STAB
 STAB BA auto
#enddef
$ *************************************************************
$ *************************************************************
$ *************************************************************
!#!Kapitel CSM Bauphasen
$ ----------------------------------- Construction Stage  10  ----------------
-PROG ASE urs:ccsmase10
KOPF Bauabschnitt BA  10 G_1
sto#ba_csm  10    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF -
GRUP   1 BA  10 T1     14.0 FAKG 1
GRUP   2 BA  10 T1     14.0 FAKG 1
GRUP   3 BA  10 T1     14.0 FAKG 1
GRUP   5 BA  10 T1     14.0 FAKG 1
GRUP   6 BA  10 T1     14.0 FAKG 1
GRUP   9 BA  10 T1     14.0 FAKG 1
GRUP  10 BA  10 T1     14.0 FAKG 1
GRUP  11 BA  10 T1     14.0 FAKG 1
LF  4010  TYP - BEZ "G_1                             " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
ENDE
$ ----------------------------------- Construction Stage  11  ----------------
-PROG ASE urs:ccsmase11
KOPF Bauabschnitt BA  11 Vorspannung
sto#ba_csm  11    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4010
GRUP   1 BA  11 T1     14.0 FAKG 1
GRUP   2 BA  11 T1     14.0 FAKG 1
GRUP   3 BA  11 T1     14.0 FAKG 1
GRUP   5 BA  11 T1     14.0 FAKG 1
GRUP   6 BA  11 T1     14.0 FAKG 1
GRUP   9 BA  11 T1     14.0 FAKG 1
GRUP  10 BA  11 T1     14.0 FAKG 1
GRUP  11 BA  11 T1     14.0 FAKG 1
LF  4011  TYP - BEZ "Vorspannung                     " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     3 PLF NEU $ zum ersten Mal angesetzt
ENDE
$ ----------------------------------- Construction Stage  15  ----------------
-PROG AQB urs:ccsmaqb15
KOPF Kriechstufe BA  15 Kriechen im Bauzustand
#include AQB_CTRL
STAB BA auto
LF 5010  TYP "G_1 "  QT   10 REF TEIL SUP PERM
LF 5011  TYP "P   "  QT   11 REF TEIL SUP PERM APAR P $ P=Vorspannung
KOMB SUM LF1 G 1 P  1 LFSP 6015  QT   15 BEZ "15 Kriechen im Bauzustan"
EIGE GRP   1 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   2 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   5 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   6 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   9 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE         MNR  11 T       40 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
EIGE         MNR  12 T       40 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
ENDE
-PROG ASE urs:ccsmase15
KOPF Bauabschnitt BA  15 Kriechen im Bauzustand
sto#ba_csm  15    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4011
KRIE 1 T    40.000 STAB AQB RKRI CSM $ alle Elemente verwenden die real creep Werte, aufgesplittet nach Belastungsalter der Lastanteile
GRUP   1 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000264 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   2 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000264 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   3 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000317 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   5 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000236 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   6 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000230 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   9 BA  15 T1     54.0 FAKG 1 PHI CSM EPS -0.0000227 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP  10 BA  15 T1     54.0 FAKG 1 PHIF CSM
GRUP  11 BA  15 T1     54.0 FAKG 1 PHIF CSM
LF  4015  TYP - BEZ "Kriechen im Bauzustand          " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     3 PLF JA  $ bereits im PLF angesetzt
   LC  6015 PLF NEU $ AQB Stab Kriechkruemmungen
ENDE
$ ----------------------------------- Construction Stage  21  ----------------
-PROG ASE urs:ccsmase21
KOPF Bauabschnitt BA  21 Plattenquervorspannung
sto#ba_csm  21    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4015
GRUP   1 BA  21 T1     54.0 FAKG 1
GRUP   2 BA  21 T1     54.0 FAKG 1
GRUP   3 BA  21 T1     54.0 FAKG 1
GRUP   5 BA  21 T1     54.0 FAKG 1
GRUP   6 BA  21 T1     54.0 FAKG 1
GRUP   9 BA  21 T1     54.0 FAKG 1
GRUP  10 BA  21 T1     54.0 FAKG 1
GRUP  11 BA  21 T1     54.0 FAKG 1
LF  4021  TYP - BEZ "Plattenquervorspannung          " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     3 PLF JA  $ bereits im PLF angesetzt
   LC     4 PLF NEU $ zum ersten Mal angesetzt
   ! incl. $ = QUAD-Vorspannung TYP V aus Vorbauabschnitt VBA= (TENDON-CS-IBA1)= 21
ENDE
$ ----------------------------------- Construction Stage  30  ----------------
-PROG ASE urs:ccsmase30
KOPF Bauabschnitt BA  30 G_2 Asphalt, Kappen
sto#ba_csm  30    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4021
GRUP   1 BA  30 T1     54.0 FAKG 1
GRUP   2 BA  30 T1     54.0 FAKG 1
GRUP   3 BA  30 T1     54.0 FAKG 1
GRUP   5 BA  30 T1     54.0 FAKG 1
GRUP   6 BA  30 T1     54.0 FAKG 1
GRUP   9 BA  30 T1     54.0 FAKG 1
GRUP  10 BA  30 T1     54.0 FAKG 1
GRUP  11 BA  30 T1     54.0 FAKG 1
LF  4030  TYP - BEZ "G_2 Asphalt, Kappen             " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     2 PLF NEU $ zum ersten Mal angesetzt
   LC     3 PLF JA  $ bereits im PLF angesetzt
   LC     4 PLF JA  $ bereits im PLF angesetzt
ENDE
$ ----------------------------------- Construction Stage  35  ----------------
-PROG AQB urs:ccsmaqb35
KOPF Kriechstufe BA  35 K+S bis VerkehrsĂĽbergabe
#include AQB_CTRL
STAB BA auto
LF 5010  TYP "G_1 "  QT   10 REF TEIL SUP PERM
LF 5011  TYP "P   "  QT   11 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
LF 5021  TYP "P   "  QT   21 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5030  TYP "G_2 "  QT   30 REF TEIL SUP PERM
KOMB SUM LF1 G 1 P  1 C 1 LFSP 6035  QT   35 BEZ "35 K+S bis VerkehrsĂĽber"
EIGE GRP   1 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   2 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   5 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   6 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   9 MNR   1 T       40 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE         MNR  11 T       40 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
EIGE         MNR  12 T       40 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
ENDE
-PROG ASE urs:ccsmase35
KOPF Bauabschnitt BA  35 K+S bis VerkehrsĂĽbergabe
sto#ba_csm  35    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4030
KRIE 1 T    40.000 STAB AQB RKRI CSM $ alle Elemente verwenden die real creep Werte, aufgesplittet nach Belastungsalter der Lastanteile
GRUP   1 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000139 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   2 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000139 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   3 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000179 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   5 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000115 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   6 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000109 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   9 BA  35 T1     94.0 FAKG 1 PHI CSM EPS -0.0000107 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP  10 BA  35 T1     94.0 FAKG 1 PHIF CSM
GRUP  11 BA  35 T1     94.0 FAKG 1 PHIF CSM
LF  4035  TYP - BEZ "K+S bis VerkehrsĂĽbergabe       " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     2 PLF JA  $ bereits im PLF angesetzt
   LC     3 PLF JA  $ bereits im PLF angesetzt
   LC     4 PLF JA  $ bereits im PLF angesetzt
   LC  6035 PLF NEU $ AQB Stab Kriechkruemmungen
ENDE
$ ----------------------------------- Construction Stage  45  ----------------
-PROG AQB urs:ccsmaqb45
KOPF Kriechstufe BA  45 K+S t-unendlich
#include AQB_CTRL
STAB BA auto
LF 5010  TYP "G_1 "  QT   10 REF TEIL SUP PERM
LF 5011  TYP "P   "  QT   11 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
LF 5021  TYP "P   "  QT   21 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5030  TYP "G_2 "  QT   30 REF TEIL SUP PERM
LF 5035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
KOMB SUM LF1 G 1 P  1 C 1 LFSP 6045  QT   45 BEZ "45 K+S t-unendlich      "
EIGE GRP   1 MNR   1 T     1697 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   2 MNR   1 T     1697 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   5 MNR   1 T     1697 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   6 MNR   1 T     1697 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   9 MNR   1 T     1697 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE         MNR  11 T     1697 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
EIGE         MNR  12 T     1697 TEMP   20.0 $ aktiviert die Spannstahlrelaxation
ENDE
-PROG ASE urs:ccsmase45
KOPF Bauabschnitt BA  45 K+S t-unendlich
sto#ba_csm  45    $ Verwendung der Variable #ba_csm in STEU ASE TEXT siehe Handbuch -> STEU KRAG
#include ASE_CTRL
SYST PLF 4035
KRIE 1 T     1697. STAB AQB RKRI CSM $ alle Elemente verwenden die real creep Werte, aufgesplittet nach Belastungsalter der Lastanteile
GRUP   1 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0001184 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   2 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0001184 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   3 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0001259 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   5 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0001064 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   6 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0001019 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP   9 BA  45 T1   1791.0 FAKG 1 PHI CSM EPS -0.0000997 PHIF CSM RELZ AUTO MNR - $ first MNR   1
GRUP  10 BA  45 T1   1791.0 FAKG 1 PHIF CSM
GRUP  11 BA  45 T1   1791.0 FAKG 1 PHIF CSM
LF  4045  TYP - BEZ "K+S t-unendlich                 " $ Eigengewicht ueber GRUP FAKG anstelle EGZ
   LC     2 PLF JA  $ bereits im PLF angesetzt
   LC     3 PLF JA  $ bereits im PLF angesetzt
   LC     4 PLF JA  $ bereits im PLF angesetzt
   LC  6045 PLF NEU $ AQB Stab Kriechkruemmungen
ENDE
$ ----------------------------------- Construction Stage  46  ----------------
-PROG AQB urs:ccsmaqb46
KOPF Kriechstufe BA  46 K+S t-unendlich
#include AQB_CTRL
STAB BA auto
LF 5010  TYP "G_1 "  QT   10 REF TEIL SUP PERM
LF 5011  TYP "P   "  QT   11 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6015  TYP "C_1 "  QT   15 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
LF 5021  TYP "P   "  QT   21 REF TEIL SUP PERM APAR P $ P=Vorspannung
LF 5030  TYP "G_2 "  QT   30 REF TEIL SUP PERM
LF 5035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6035  TYP "C_1 "  QT   35 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
LF 5045  TYP "C_2 "  QT   45 REF TEIL SUP PERM GAMU 1 1 $ K+S statisch unbestimmter Anteil GAMU wie P ! -> STEU GAMC
LF 6045  TYP "C_2 "  QT   45 REF TEIL SUP PERM GAMU 1 1 $ K+S Querschnittskriechen immer 1.0 fach
KOMB SUM LF1 G 1 P  1 C 1 LFSP 6046  QT   46 BEZ "46 K+S t-unendlich      "
EIGE GRP   1 MNR   1 T    34803 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   2 MNR   1 T    34803 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
EIGE GRP   5 MNR   1 T    34803 T0 14 TS 3 RH   80.0 TEMP   20.0 $ Kriech- und Schwindwerte werden in Abhängigkeit von deff neu gerechnet
